<!DOCTYPE html>
<html>
<head>
  <title>Répondre au devis · OpenDevis</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <style>
    body { background: #FFFFFF; font-family: system-ui, sans-serif; color: #2C2A25; }
    .portal-card {
      background: #fff;
      border: 1px solid #C8C4BC;
      border-radius: 12px;
      padding: 32px;
      max-width: 600px;
      margin: 48px auto;
    }
    .brand { font-weight: 800; color: #2C2A25; font-size: 1.1rem; letter-spacing: -0.3px; }
    .info-block { background: #F5F3EE; border: 1px solid #C8C4BC; border-radius: 10px; padding: 16px 20px; margin: 20px 0; }
    .price-input {
      border: 2px solid #C8C4BC; border-radius: 8px; font-size: 1.2rem;
      padding: 12px 16px; width: 100%;
    }
    .price-input:focus { outline: none; border-color: #2C2A25; }
    .btn-submit {
      background: #2C2A25; color: #fff; border: none;
      padding: 12px 28px; border-radius: 8px; font-weight: 600;
      font-size: 1rem; cursor: pointer; width: 100%;
    }
    .btn-submit:hover { background: #1a1916; }
    .btn-decline {
      background: transparent; color: #4A4640;
      border: 1px solid #C8C4BC; padding: 10px 20px;
      border-radius: 8px; font-weight: 500; cursor: pointer; width: 100%;
    }
    .btn-decline:hover { border-color: #4A4640; color: #2C2A25; }
    .status-responded { background: #D4EDDA; color: #2D6A4F; padding: 16px; border-radius: 10px; margin-bottom: 20px; }
    .status-declined  { background: #F8D7DA; color: #842029; padding: 16px; border-radius: 10px; }
    .status-expired   { background: #FFF3CD; color: #856404; padding: 16px; border-radius: 10px; }
  </style>
</head>
<body>
  <div style="text-align: center; padding: 24px 0 0;">
    <span class="brand">OpenDevis</span>
  </div>

  <div class="portal-card">
    <% if @bidding_request.status == "responded" %>
      <h2 style="font-weight: 700; font-size: 1.3rem; margin-bottom: 4px;">✅ Devis envoyé</h2>
      <p style="color: #4A4640; font-size: 0.9rem; margin-bottom: 0;">
        Bonjour <%= @bidding_request.artisan.name %>, votre réponse a bien été enregistrée.
      </p>

      <div class="status-responded">
        <strong>Réponse enregistrée ✓</strong>
      </div>

      <div class="info-block">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Catégorie</div>
            <div style="font-weight: 600;"><%= @bidding_request.work_category.name %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Votre prix</div>
            <div style="font-weight: 600; color: #2D6A4F;">
              <%= number_to_currency(@bidding_request.price_total, unit: "€", format: "%n %u") %> HT
            </div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Envoyé le</div>
            <div style="font-weight: 600;"><%= @bidding_request.responded_at.strftime("%d/%m/%Y à %H:%M") %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Date limite</div>
            <div style="font-weight: 600;"><%= @bidding_request.bidding_round.deadline.strftime("%d/%m/%Y") %></div>
          </div>
        </div>
        <% if @bidding_request.artisan_comment.present? %>
          <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #C8C4BC;">
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 4px;">Commentaire inclus</div>
            <div style="font-size: 0.9rem; color: #2C2A25; white-space: pre-wrap;"><%= @bidding_request.artisan_comment %></div>
          </div>
        <% end %>
      </div>

      <% unless @bidding_request.bidding_round.deadline_passed? %>
        <p style="color: #4A4640; font-size: 0.85rem; margin-bottom: 16px;">
          Vous pouvez modifier votre prix jusqu'à la date limite
          (<%= @bidding_request.bidding_round.deadline.strftime("%d/%m/%Y à %H:%M") %>).
        </p>

        <%= form_with url: artisan_portal_submit_path(@bidding_request.token), method: :post do |f| %>
          <div style="margin-bottom: 16px;">
            <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
              Prix total HT (€)
            </label>
            <div style="display: flex; align-items: center; border: 2px solid #C8C4BC; border-radius: 8px; overflow: hidden;">
              <input type="number"
                     name="price_total"
                     step="0.01"
                     min="0.01"
                     value="<%= @bidding_request.price_total %>"
                     style="border: none; padding: 12px 16px; font-size: 1.1rem; flex: 1; outline: none; background: transparent;">
              <span style="padding: 0 16px; color: #4A4640; font-size: 1.1rem;">€ HT</span>
            </div>
          </div>
          <div style="margin-bottom: 16px;">
            <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
              Commentaire (optionnel)
            </label>
            <textarea name="artisan_comment" rows="4" placeholder="Décrivez ce qui est inclus dans votre devis (prestations, matériaux, délais…)"
                      style="width: 100%; border: 2px solid #C8C4BC; border-radius: 8px; padding: 12px 16px; font-size: 0.9rem; resize: vertical; font-family: inherit;"><%= @bidding_request.artisan_comment %></textarea>
          </div>
          <button type="submit" class="btn-submit">
            Mettre à jour
          </button>
        <% end %>
      <% end %>

    <% elsif @bidding_request.status == "declined" %>
      <h2 style="font-weight: 700; font-size: 1.3rem; margin-bottom: 4px;">Demande de devis</h2>
      <p style="color: #4A4640; font-size: 0.9rem; margin-bottom: 0;">
        Bonjour <%= @bidding_request.artisan.name %>, voici la demande de devis reçue.
      </p>
      <div class="info-block" style="margin-top: 20px;">
        <div style="font-weight: 600;"><%= @bidding_request.work_category.name %></div>
      </div>
      <div class="status-declined">
        <strong>Demande déclinée</strong><br>
        Vous avez décliné cette demande de devis.
      </div>

    <% elsif @bidding_request.status == "expired" %>
      <h2 style="font-weight: 700; font-size: 1.3rem; margin-bottom: 4px;">Demande de devis</h2>
      <p style="color: #4A4640; font-size: 0.9rem; margin-bottom: 0;">
        Bonjour <%= @bidding_request.artisan.name %>, voici la demande de devis reçue.
      </p>
      <div class="status-expired" style="margin-top: 20px;">
        <strong>Délai dépassé</strong><br>
        La date limite de réponse est passée.
      </div>

    <% elsif @bidding_request.status == "replaced" %>
      <h2 style="font-weight: 700; font-size: 1.3rem; margin-bottom: 4px;">Demande de devis</h2>
      <p style="color: #4A4640; font-size: 0.9rem; margin-bottom: 0;">
        Bonjour <%= @bidding_request.artisan.name %>.
      </p>
      <div class="status-expired" style="margin-top: 20px;">
        <strong>Demande annulée</strong><br>
        Cette demande a été annulée par le donneur d'ordre.
      </div>

    <% else %>
      <h2 style="font-weight: 700; font-size: 1.3rem; margin-bottom: 4px;">Demande de devis</h2>
      <p style="color: #4A4640; font-size: 0.9rem; margin-bottom: 0;">
        Bonjour <%= @bidding_request.artisan.name %>, voici la demande de devis reçue.
      </p>

      <div class="info-block">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Catégorie</div>
            <div style="font-weight: 600;"><%= @bidding_request.work_category.name %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Localisation</div>
            <div style="font-weight: 600;"><%= @bidding_request.bidding_round.project.location_zip %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Standing</div>
            <div style="font-weight: 600;"><%= @bidding_request.bidding_round.standing_label %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Date limite</div>
            <div style="font-weight: 600;"><%= @bidding_request.bidding_round.deadline.strftime("%d/%m/%Y") %></div>
          </div>
          <% if @bidding_request.bidding_round.project.total_surface_sqm.present? %>
            <div>
              <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Surface</div>
              <div style="font-weight: 600;"><%= @bidding_request.bidding_round.project.total_surface_sqm %> m²</div>
            </div>
          <% end %>
          <% if @bidding_request.bidding_round.project.room_count.present? %>
            <div>
              <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 2px;">Pièces</div>
              <div style="font-weight: 600;"><%= @bidding_request.bidding_round.project.room_count %></div>
            </div>
          <% end %>
        </div>
      </div>

      <% if @error %>
        <div style="background: #FFF3CD; color: #856404; border: 1px solid #ffe69c; border-radius: 8px; padding: 12px 16px; margin-bottom: 16px;">
          <%= @error %>
        </div>
      <% end %>

      <% if @bidding_request.bidding_round.deadline_passed? %>
        <div class="status-expired">
          <strong>Délai dépassé</strong><br>
          La date limite de réponse est passée.
        </div>
      <% else %>
        <%= form_with url: artisan_portal_submit_path(@bidding_request.token), method: :post,
              style: "margin-top: 24px;" do |f| %>
          <div style="margin-bottom: 16px;">
            <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
              Votre prix total HT (€)
            </label>
            <div style="display: flex; align-items: center; border: 2px solid #C8C4BC; border-radius: 8px; overflow: hidden;">
              <input type="number"
                     name="price_total"
                     step="0.01"
                     min="0.01"
                     placeholder="Ex : 3500.00"
                     style="border: none; padding: 12px 16px; font-size: 1.1rem; flex: 1; outline: none; background: transparent;">
              <span style="padding: 0 16px; color: #4A4640; font-size: 1.1rem;">€ HT</span>
            </div>
            <p style="font-size: 0.78rem; color: #4A4640; margin-top: 6px;">
              Indiquez votre prix de main-d'œuvre et fournitures, hors taxes.
            </p>
          </div>
          <div style="margin-bottom: 16px;">
            <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
              Commentaire (optionnel)
            </label>
            <textarea name="artisan_comment" rows="4" placeholder="Décrivez ce qui est inclus dans votre devis (prestations, matériaux, délais…)"
                      style="width: 100%; border: 2px solid #C8C4BC; border-radius: 8px; padding: 12px 16px; font-size: 0.9rem; resize: vertical; font-family: inherit;"></textarea>
          </div>

          <button type="submit" class="btn-submit" style="margin-bottom: 12px;">
            Envoyer mon devis
          </button>
        <% end %>

        <%= form_with url: artisan_portal_submit_path(@bidding_request.token), method: :post do |f| %>
          <input type="hidden" name="decline" value="1">
          <button type="submit" class="btn-decline"
                  onclick="return confirm('Êtes-vous sûr de vouloir décliner cette demande ?');">
            Décliner la demande
          </button>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <div style="max-width: 600px; margin: 0 auto 40px; padding: 0 16px; text-align: center;">
    <div style="background: #F5F3EE; border: 1px solid #C8C4BC; border-radius: 10px; padding: 16px 20px; font-size: 0.85rem; color: #4A4640;">
      💡 Vous avez un compte ?
      <%= link_to "Connectez-vous", new_artisan_session_path,
            style: "color: #2C2A25; font-weight: 600; text-decoration: underline;" %>
      pour gérer toutes vos demandes depuis votre tableau de bord.
    </div>
  </div>

  <div style="text-align: center; padding-bottom: 40px; color: #4A4640; font-size: 0.8rem;">
    OpenDevis · Estimation de travaux
  </div>
</body>
</html>
