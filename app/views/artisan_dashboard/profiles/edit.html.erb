<div style="max-width: 600px; margin: 0 auto; padding: 32px 24px;">
  <%= link_to "← Retour au tableau de bord", artisan_dashboard_root_path,
        style: "color: #9B9588; text-decoration: none; font-size: 0.9rem;" %>

  <h2 style="font-weight: 700; color: #2C2A25; margin-top: 16px; margin-bottom: 4px;">Mon profil</h2>
  <p style="color: #9B9588; font-size: 0.9rem; margin-bottom: 28px;">Mettez à jour vos informations professionnelles.</p>

  <div style="background: #fff; border: 1px solid #E8E4DC; border-radius: 12px; padding: 28px;">
    <%= form_with model: @artisan, url: artisan_dashboard_profile_path, method: :patch do |f| %>
      <% if @artisan.errors.any? %>
        <div style="background: #F8D7DA; color: #842029; border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-size: 0.88rem;">
          <% @artisan.errors.full_messages.each do |msg| %>
            <div><%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <% field_style = "width: 100%; border: 1px solid #E8E4DC; border-radius: 8px; padding: 10px 14px; font-size: 0.93rem; box-sizing: border-box; outline: none; background: #fff;" %>
      <% label_style = "font-size: 0.83rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 6px;" %>

      <div style="margin-bottom: 16px;">
        <%= f.label :name, "Nom complet", style: label_style %>
        <%= f.text_field :name, style: field_style %>
      </div>
      <div style="margin-bottom: 16px;">
        <%= f.label :company_name, "Nom de l'entreprise", style: label_style %>
        <%= f.text_field :company_name, style: field_style %>
      </div>
      <div style="margin-bottom: 16px;">
        <%= f.label :phone, "Téléphone", style: label_style %>
        <%= f.telephone_field :phone, style: field_style %>
      </div>
      <div style="margin-bottom: 16px;">
        <%= f.label :postcode, "Code postal (zone d'intervention)", style: label_style %>
        <%= f.text_field :postcode, style: field_style %>
      </div>
      <div style="margin-bottom: 16px;">
        <%= f.label :certifications, "Certifications (ex : RGE, Qualibat)", style: label_style %>
        <%= f.text_area :certifications, rows: 2, style: field_style %>
      </div>
      <div style="margin-bottom: 24px;">
        <%= f.label :portfolio_url, "URL portfolio / site web", style: label_style %>
        <%= f.url_field :portfolio_url, style: field_style %>
      </div>

      <button type="submit" style="background: #2C2A25; color: #fff; border: none; border-radius: 8px;
              padding: 12px 28px; font-size: 1rem; font-weight: 600; cursor: pointer;">
        Enregistrer
      </button>
    <% end %>
  </div>
</div>
