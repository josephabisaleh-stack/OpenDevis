<style>
  .ad-container { max-width: 700px; margin: 0 auto; padding: 32px 24px; }
  .ad-info-block { background: #F5F3EE; border: 1px solid #C8C4BC; border-radius: 10px; padding: 20px; margin: 20px 0; }
  .ad-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ad-info-label { font-size: 0.75rem; color: #4A4640; margin-bottom: 2px; }
  .ad-info-value { font-weight: 600; color: #2C2A25; font-size: 0.9rem; }
  .ad-status-responded { background: #D4EDDA; color: #2D6A4F; padding: 14px 18px; border-radius: 10px; margin-bottom: 16px; }
  .ad-status-declined  { background: #F8D7DA; color: #842029; padding: 14px 18px; border-radius: 10px; }
  .ad-status-expired   { background: #FFF3CD; color: #856404; padding: 14px 18px; border-radius: 10px; }
</style>

<div class="ad-container">
  <%= link_to "← Retour aux demandes", artisan_dashboard_root_path,
        style: "color: #4A4640; text-decoration: none; font-size: 0.9rem;" %>

  <h2 style="font-weight: 700; color: #2C2A25; margin-top: 16px; margin-bottom: 4px;">
    <%= @bidding_request.work_category.name %>
  </h2>
  <p style="color: #4A4640; font-size: 0.9rem; margin-bottom: 20px;">
    Demande de devis reçue · Limite : <%= @bidding_request.bidding_round.deadline.strftime("%d/%m/%Y à %H:%M") %>
  </p>

  <div class="ad-info-block">
    <div class="ad-info-grid">
      <div>
        <div class="ad-info-label">Catégorie</div>
        <div class="ad-info-value"><%= @bidding_request.work_category.name %></div>
      </div>
      <div>
        <div class="ad-info-label">Localisation</div>
        <div class="ad-info-value"><%= @bidding_request.bidding_round.project.location_zip %></div>
      </div>
      <div>
        <div class="ad-info-label">Standing</div>
        <div class="ad-info-value"><%= @bidding_request.bidding_round.standing_label %></div>
      </div>
      <div>
        <div class="ad-info-label">Date limite</div>
        <div class="ad-info-value"><%= @bidding_request.bidding_round.deadline.strftime("%d/%m/%Y") %></div>
      </div>
      <% if @bidding_request.bidding_round.project.total_surface_sqm.present? %>
        <div>
          <div class="ad-info-label">Surface</div>
          <div class="ad-info-value"><%= @bidding_request.bidding_round.project.total_surface_sqm.to_i %> m²</div>
        </div>
      <% end %>
      <% if @bidding_request.bidding_round.project.room_count.present? %>
        <div>
          <div class="ad-info-label">Pièces</div>
          <div class="ad-info-value"><%= @bidding_request.bidding_round.project.room_count %></div>
        </div>
      <% end %>
    </div>
  </div>

  <% if @bidding_request.status == "responded" %>
    <div class="ad-status-responded">
      <strong>✅ Devis envoyé</strong> ·
      <%= number_to_currency(@bidding_request.price_total, unit: "€", format: "%n %u") %> HT
      · le <%= @bidding_request.responded_at.strftime("%d/%m/%Y à %H:%M") %>
    </div>

    <% if @bidding_request.artisan_comment.present? %>
      <div style="background: #F5F3EE; border: 1px solid #C8C4BC; border-radius: 8px; padding: 12px 16px; margin-bottom: 16px;">
        <div style="font-size: 0.75rem; color: #4A4640; margin-bottom: 4px;">Commentaire inclus</div>
        <div style="font-size: 0.9rem; color: #2C2A25; white-space: pre-wrap;"><%= @bidding_request.artisan_comment %></div>
      </div>
    <% end %>

    <% unless @bidding_request.bidding_round.deadline_passed? %>
      <p style="color: #4A4640; font-size: 0.85rem; margin-bottom: 16px;">
        Vous pouvez modifier votre prix jusqu'à la date limite.
      </p>
      <%= form_with url: submit_price_artisan_dashboard_request_path(@bidding_request), method: :post do |f| %>
        <div style="margin-bottom: 16px;">
          <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
            Nouveau prix total HT (€)
          </label>
          <div style="display: flex; align-items: center; border: 2px solid #C8C4BC; border-radius: 8px; overflow: hidden;">
            <input type="number" name="price_total" step="0.01" min="0.01"
                   value="<%= @bidding_request.price_total %>"
                   style="border: none; padding: 12px 16px; font-size: 1.1rem; flex: 1; outline: none; background: transparent;">
            <span style="padding: 0 16px; color: #4A4640; font-size: 1.1rem;">€ HT</span>
          </div>
        </div>
        <div style="margin-bottom: 16px;">
          <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
            Commentaire (optionnel)
          </label>
          <textarea name="artisan_comment" rows="4" placeholder="Décrivez ce qui est inclus dans votre devis (prestations, matériaux, délais…)"
                    style="width: 100%; border: 2px solid #C8C4BC; border-radius: 8px; padding: 12px 16px; font-size: 0.9rem; resize: vertical; font-family: inherit;"><%= @bidding_request.artisan_comment %></textarea>
        </div>
        <button type="submit" style="background: #2C2A25; color: #fff; border: none; border-radius: 8px;
                padding: 11px 24px; font-size: 0.95rem; font-weight: 600; cursor: pointer;">
          Mettre à jour
        </button>
      <% end %>
    <% end %>

  <% elsif @bidding_request.status == "declined" %>
    <div class="ad-status-declined"><strong>Demande déclinée</strong> · Vous avez décliné cette demande.</div>

  <% elsif @bidding_request.status == "expired" %>
    <div class="ad-status-expired"><strong>Délai dépassé</strong> · La date limite de réponse est passée.</div>

  <% elsif @bidding_request.status == "replaced" %>
    <div class="ad-status-expired"><strong>Demande annulée</strong> · Cette demande a été annulée par le donneur d'ordre.</div>

  <% else %>
    <% if @error %>
      <div style="background: #FFF3CD; color: #856404; border: 1px solid #ffe69c; border-radius: 8px; padding: 12px 16px; margin-bottom: 16px;">
        <%= @error %>
      </div>
    <% end %>

    <% if @bidding_request.bidding_round.deadline_passed? %>
      <div class="ad-status-expired"><strong>Délai dépassé</strong> · La date limite de réponse est passée.</div>
    <% else %>
      <%= form_with url: submit_price_artisan_dashboard_request_path(@bidding_request), method: :post do |f| %>
        <div style="margin-bottom: 16px;">
          <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
            Votre prix total HT (€)
          </label>
          <div style="display: flex; align-items: center; border: 2px solid #C8C4BC; border-radius: 8px; overflow: hidden;">
            <input type="number" name="price_total" step="0.01" min="0.01"
                   placeholder="Ex : 3500.00"
                   style="border: none; padding: 12px 16px; font-size: 1.1rem; flex: 1; outline: none; background: transparent;">
            <span style="padding: 0 16px; color: #4A4640; font-size: 1.1rem;">€ HT</span>
          </div>
          <p style="font-size: 0.78rem; color: #4A4640; margin-top: 6px;">
            Indiquez votre prix de main-d'œuvre et fournitures, hors taxes.
          </p>
        </div>
        <div style="margin-bottom: 16px;">
          <label style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; display: block; margin-bottom: 8px;">
            Commentaire (optionnel)
          </label>
          <textarea name="artisan_comment" rows="4" placeholder="Décrivez ce qui est inclus dans votre devis (prestations, matériaux, délais…)"
                    style="width: 100%; border: 2px solid #C8C4BC; border-radius: 8px; padding: 12px 16px; font-size: 0.9rem; resize: vertical; font-family: inherit;"></textarea>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <button type="submit" style="background: #2C2A25; color: #fff; border: none; border-radius: 8px;
                  padding: 12px 28px; font-size: 1rem; font-weight: 600; cursor: pointer; flex: 1; min-width: 160px;">
            Envoyer mon devis
          </button>
        </div>
      <% end %>

      <div style="margin-top: 12px;">
        <%= form_with url: decline_artisan_dashboard_request_path(@bidding_request), method: :post do |f| %>
          <button type="submit"
                  onclick="return confirm('Êtes-vous sûr de vouloir décliner cette demande ?')"
                  style="background: transparent; color: #4A4640; border: 1px solid #C8C4BC;
                         padding: 10px 20px; border-radius: 8px; font-weight: 500; cursor: pointer; width: 100%;">
            Décliner la demande
          </button>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
