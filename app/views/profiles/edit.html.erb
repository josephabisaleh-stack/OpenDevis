<% content_for :title, "Mon profil — OpenDevis" %>
<% content_for :head do %>
<style>
  body { background-color: #FFFFFF; }
  .profile-card {
    background: #fff;
    border: 1px solid #C8C4BC;
    border-radius: 12px;
    padding: 2rem;
  }
  .avatar-circle {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: #2C2A25;
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .form-label { font-size: 0.88rem; font-weight: 500; color: #2C2A25; margin-bottom: 0.3rem; }
  .form-control {
    border: 1px solid #C8C4BC;
    border-radius: 8px;
    font-size: 0.92rem;
    color: #2C2A25;
    background: #FFFFFF;
    padding: 0.5rem 0.75rem;
  }
  .form-control:focus {
    border-color: #2C2A25;
    box-shadow: none;
    background: #fff;
  }
  .section-title { font-size: 1rem; font-weight: 600; color: #2C2A25; margin-bottom: 1rem; }
  .btn-save {
    background: #2C2A25; color: #fff; border: none;
    border-radius: 8px; font-weight: 500; font-size: 0.9rem;
    padding: 0.5rem 1.25rem; cursor: pointer;
    transition: background 0.12s;
  }
  .btn-save:hover { background: #1a1916; }
</style>
<% end %>

<div class="container py-5" style="max-width: 620px;">
  <div class="d-flex align-items-center gap-3 mb-4">
    <div class="avatar-circle">
      <%= (@user.full_name&.first || @user.email.first).upcase %>
    </div>
    <div>
      <div style="font-size: 1.3rem; font-weight: 700; color: #2C2A25;">
        <%= @user.full_name.presence || "Mon profil" %>
      </div>
      <div style="font-size: 0.88rem; color: #4A4640;"><%= @user.email %></div>
    </div>
  </div>

  <%= form_with model: @user, url: profile_path, method: :patch, class: "profile-card" do |f| %>
    <% if @user.errors.any? %>
      <div class="alert" style="background: #F8D7DA; border: none; border-radius: 8px; color: #842029; font-size: 0.88rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem;">
        <% @user.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="section-title">Informations personnelles</div>

    <div class="mb-3">
      <%= f.label :full_name, "Nom complet", class: "form-label" %>
      <%= f.text_field :full_name, class: "form-control", placeholder: "Jean Dupont" %>
    </div>

    <div class="mb-3">
      <%= f.label :phone, "Téléphone", class: "form-label" %>
      <%= f.text_field :phone, class: "form-control", placeholder: "+33 6 12 34 56 78" %>
    </div>

    <div class="mb-4">
      <%= f.label :location, "Localisation", class: "form-label" %>
      <%= f.text_field :location, class: "form-control", placeholder: "Paris, France" %>
    </div>

    <div class="d-flex align-items-center justify-content-between">
      <%= link_to "Annuler", profile_path,
            style: "font-size: 0.88rem; color: #4A4640; text-decoration: none;" %>
      <%= f.submit "Enregistrer", class: "btn-save" %>
    </div>
  <% end %>
</div>
