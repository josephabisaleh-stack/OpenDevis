<% content_for :title, "OpenDevis — Devis de rénovation gratuit et instantané" %>
<% content_for :description, "Estimez le coût de vos travaux de rénovation en quelques minutes. OpenDevis génère des devis détaillés par pièce, gratuit et sans inscription." %>

<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenDevis",
    "url": "https://opendevis.com",
    "description": "Estimez le coût de vos travaux de rénovation en quelques minutes. OpenDevis génère des devis détaillés par pièce, gratuit et sans inscription.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "inLanguage": "fr-FR",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR",
      "description": "Gratuit pour toujours. Sans carte bancaire."
    }
  }
  </script>
<% end %>

<%# ── HERO ──────────────────────────────────────────────────────────────── %>
<section class="hero-v2">
  <div class="container py-5 py-lg-6">
    <div class="row align-items-center g-5">

      <%# Colonne gauche : texte %>
      <div class="col-lg-6">
        <div class="hero-badge mb-4">
          <span class="hero-badge-dot">
            <span class="hero-badge-ping"></span>
          </span>
          Reprenez le contrôle de votre rénovation
        </div>

        <h1 class="hero-v2-title mb-4">
          Obtenez le devis de vos
          <span class="hero-words-loader">
            <span class="hero-words">
              <span class="hero-word">travaux</span>
              <span class="hero-word">rénovations</span>
              <span class="hero-word">isolations</span>
              <span class="hero-word">travaux</span>
            </span>
          </span><br>
          facilement et instantanément.
        </h1>

        <p class="hero-v2-lead mb-4">
          Visitez, chiffrez, décidez l'esprit léger. OpenDevis vous guide pas à pas pour estimer chaque poste de dépense, à votre rythme et en totale autonomie, sans dépendre de l'agenda de quiconque.
        </p>

        <%# Avis clients %>
        <div class="hero-social-proof mb-5">
          <div class="hero-avatars">
            <div class="hero-avatar" style="background: #fbbf24;">S</div>
            <div class="hero-avatar" style="background: #34d399;">M</div>
            <div class="hero-avatar" style="background: #60a5fa;">A</div>
            <div class="hero-avatar" style="background: #f87171;">L</div>
          </div>
          <div>
            <div class="hero-stars">
              <i class="fa fa-star"></i>
              <i class="fa fa-star"></i>
              <i class="fa fa-star"></i>
              <i class="fa fa-star"></i>
              <i class="fa fa-star"></i>
            </div>
            <p class="hero-social-label">
              <strong>4,9/5</strong> · Plébiscité par +200 propriétaires
            </p>
          </div>
        </div>

        <% if user_signed_in? %>
          <%= link_to projects_path, class: "btn hero-v2-cta" do %>
            Mes projets <i class="fa fa-arrow-right ms-2"></i>
          <% end %>
        <% else %>
          <%= link_to new_user_registration_path, class: "btn hero-v2-cta" do %>
            Obtenir mon estimation <i class="fa fa-arrow-right ms-2"></i>
          <% end %>
        <% end %>
      </div>

      <%# Colonne droite : carte mock UI %>
      <div class="col-lg-6 d-flex justify-content-center justify-content-lg-end">
        <div class="hero-v2-card-wrap">
          <div class="hero-v2-card-float">
          <div class="hero-v2-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <div>
                <p class="hero-v2-card-label">Projet en cours</p>
                <p class="hero-v2-card-title">Appartement Paris 11e</p>
              </div>
              <div class="hero-v2-card-icon">
                <i class="fa fa-home fa-lg text-primary"></i>
              </div>
            </div>

            <div class="hero-v2-items">
              <div class="hero-v2-item">
                <div class="d-flex align-items-center gap-3">
                  <div class="hero-v2-item-icon hero-v2-item-icon--orange">
                    <i class="fa fa-utensils fa-sm"></i>
                  </div>
                  <div>
                    <p class="hero-v2-item-name">Cuisine complète</p>
                    <p class="hero-v2-item-sub">12m² • Dépose + Pose</p>
                  </div>
                </div>
                <p class="hero-v2-item-price">6 450 €</p>
              </div>

              <div class="hero-v2-item">
                <div class="d-flex align-items-center gap-3">
                  <div class="hero-v2-item-icon hero-v2-item-icon--cyan">
                    <i class="fa fa-bath fa-sm"></i>
                  </div>
                  <div>
                    <p class="hero-v2-item-name">Salle de bain</p>
                    <p class="hero-v2-item-sub">5m² • Rafraîchissement</p>
                  </div>
                </div>
                <p class="hero-v2-item-price">3 200 €</p>
              </div>
            </div>

            <div class="hero-v2-card-footer">
              <div>
                <p class="hero-v2-footer-label">Enveloppe globale estimée</p>
                <p class="hero-v2-footer-total">9 650 € <span class="hero-v2-footer-ttc">TTC</span></p>
              </div>
              <div class="hero-v2-check-btn">
                <i class="fa fa-check"></i>
              </div>
            </div>
          </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ── FONCTIONNALITÉS ─────────────────────────────────────────────────────── %>
<section class="py-6 bg-white">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold">Tout ce qu'il faut pour chiffrer un chantier</h2>
      <p class="text-muted">De la première pièce au devis final, OpenDevis gère la structure.</p>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-card h-100 p-4 rounded-3 border">
          <div class="feature-icon bg-primary-subtle text-primary mb-3">
            <i class="fa fa-folder-open fa-lg"></i>
          </div>
          <h5 class="fw-bold">Projets</h5>
          <p class="text-muted mb-0">
            Organisez chaque chantier comme un projet. Suivez le statut (brouillon, envoyé, accepté), la surface, la classe énergétique et le lien du bien — tout au même endroit.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-card h-100 p-4 rounded-3 border">
          <div class="feature-icon bg-warning-subtle text-warning mb-3">
            <i class="fa fa-vector-square fa-lg"></i>
          </div>
          <h5 class="fw-bold">Pièces</h5>
          <p class="text-muted mb-0">
            Décomposez chaque projet pièce par pièce avec surface, périmètre et hauteur sous plafond. Vos devis reflètent la géométrie réelle des espaces.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-card h-100 p-4 rounded-3 border">
          <div class="feature-icon bg-success-subtle text-success mb-3">
            <i class="fa fa-list-check fa-lg"></i>
          </div>
          <h5 class="fw-bold">Postes & matériaux</h5>
          <p class="text-muted mb-0">
            Sélectionnez les matériaux depuis un catalogue partagé, saisissez les quantités et laissez OpenDevis calculer automatiquement vos totaux HT et TTC.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ── COMMENT ÇA MARCHE ───────────────────────────────────────────────────── %>
<section class="py-6">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold">Comment ça marche</h2>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-3 text-center">
        <div class="step-number mx-auto mb-3">1</div>
        <h6 class="fw-bold">Créez un projet</h6>
        <p class="text-muted small">Ajoutez la localisation, la surface et la classe énergétique. Faites évoluer le statut au fil du temps.</p>
      </div>
      <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center text-muted">
        <i class="fa fa-arrow-right fa-lg"></i>
      </div>
      <div class="col-md-3 text-center">
        <div class="step-number mx-auto mb-3">2</div>
        <h6 class="fw-bold">Ajoutez les pièces</h6>
        <p class="text-muted small">Définissez les dimensions de chaque pièce. OpenDevis garde la structure claire et navigable.</p>
      </div>
      <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center text-muted">
        <i class="fa fa-arrow-right fa-lg"></i>
      </div>
      <div class="col-md-3 text-center">
        <div class="step-number mx-auto mb-3">3</div>
        <h6 class="fw-bold">Construisez votre devis</h6>
        <p class="text-muted small">Choisissez les matériaux, entrez les quantités — les totaux se mettent à jour sur l'ensemble du projet.</p>
      </div>
    </div>
  </div>
</section>

<%# ── APPEL À L'ACTION ────────────────────────────────────────────────────── %>
<% unless user_signed_in? %>
  <section class="py-6 bg-primary text-white">
    <div class="container text-center">
      <h2 class="fw-bold mb-3">Prêt à créer votre premier devis ?</h2>
      <p class="lead mb-4 opacity-75">Gratuit pour toujours. Sans carte bancaire.</p>
      <%= link_to "Créer mon compte", new_user_registration_path, class: "btn btn-light btn-lg px-5 fw-bold text-primary" %>
    </div>
  </section>
<% end %>
