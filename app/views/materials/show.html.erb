<div class="container py-4" style="max-width: 560px;">
  <%= link_to "← Catalogue", materials_path, class: "od-back-link" %>

  <div class="od-form-card">
    <div style="font-size: 1.2rem; font-weight: 700; color: #2C2A25; margin-bottom: 0.25rem;">
      <%= [@material.brand, @material.reference].compact.join(" — ") %>
    </div>
    <% if @material.work_category %>
      <span style="background: #EDE9E0; color: #4A4640; border-radius: 20px; padding: 0.25em 0.75em; font-size: 0.8rem; display: inline-block; margin-bottom: 1.25rem;">
        <%= @material.work_category.name %>
      </span>
    <% end %>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div>
        <div style="font-size: 0.78rem; color: #4A4640; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">Unité</div>
        <div style="font-size: 1rem; font-weight: 600; color: #2C2A25; margin-top: 0.2rem;"><%= @material.unit || "—" %></div>
      </div>
      <div>
        <div style="font-size: 0.78rem; color: #4A4640; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">Prix HT</div>
        <div style="font-size: 1rem; font-weight: 600; color: #2C2A25; margin-top: 0.2rem;">
          <%= number_to_currency(@material.public_price_exVAT, unit: "€", format: "%n %u",
                separator: ",", delimiter: "\u202F") %>
        </div>
      </div>
      <div>
        <div style="font-size: 0.78rem; color: #4A4640; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">Taux TVA</div>
        <div style="font-size: 1rem; font-weight: 600; color: #2C2A25; margin-top: 0.2rem;">
          <%= @material.vat_rate ? "#{@material.vat_rate}%" : "—" %>
        </div>
      </div>
    </div>
  </div>
</div>
