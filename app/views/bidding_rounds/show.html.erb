<% content_for :head do %>
<style>
  .br-status-badge {
    display: inline-block;
    padding: 0.3em 0.8em;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
  }
  .br-status-draft      { background: #EDE9E0; color: #6B6560; }
  .br-status-sent       { background: #D0E8F5; color: #1A5C80; }
  .br-status-in_progress { background: #FFF3CD; color: #856404; }
  .br-status-completed  { background: #D4EDDA; color: #2D6A4F; }
  .br-status-cancelled  { background: #F8D7DA; color: #842029; }

  .req-status-badge {
    font-size: 0.75rem;
    padding: 0.2em 0.6em;
    border-radius: 20px;
    font-weight: 500;
  }
  .req-pending   { background: #EDE9E0; color: #6B6560; }
  .req-sent      { background: #D0E8F5; color: #1A5C80; }
  .req-responded { background: #D4EDDA; color: #2D6A4F; }
  .req-declined  { background: #F8D7DA; color: #842029; }
  .req-expired   { background: #F8D7DA; color: #842029; }
  .req-replaced  { background: #EDE9E0; color: #9B9588; }

  .cat-group { border: 1px solid #E8E4DC; border-radius: 10px; background: #fff; margin-bottom: 16px; overflow: hidden; }
  .cat-group-header {
    padding: 14px 20px;
    background: #FAFAF7;
    border-bottom: 1px solid #E8E4DC;
    font-weight: 700;
    color: #2C2A25;
  }
  .artisan-row {
    padding: 14px 20px;
    border-bottom: 1px solid #F5F3EF;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .artisan-row:last-child { border-bottom: none; }
  .artisan-avatar-sm {
    width: 36px; height: 36px; border-radius: 50%;
    background: #E8E4DC; color: #6B6560;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.85rem; flex-shrink: 0;
  }
  .progress-card {
    border: 1px solid #E8E4DC;
    border-radius: 10px;
    background: #fff;
    padding: 20px 24px;
    margin-bottom: 24px;
  }
</style>
<% end %>

<%
  status_labels = {
    "draft"       => ["Brouillon",    "br-status-draft"],
    "sent"        => ["Envoyé",       "br-status-sent"],
    "in_progress" => ["En cours",     "br-status-in_progress"],
    "completed"   => ["Terminé",      "br-status-completed"],
    "cancelled"   => ["Annulé",       "br-status-cancelled"]
  }
  req_labels = {
    "pending"   => ["En attente", "req-pending"],
    "sent"      => ["Envoyé",     "req-sent"],
    "responded" => ["Répondu",    "req-responded"],
    "declined"  => ["Décliné",    "req-declined"],
    "expired"   => ["Expiré",     "req-expired"],
    "replaced"  => ["Remplacé",   "req-replaced"]
  }
  sl, sc = status_labels[@bidding_round.status] || ["Inconnu", "br-status-draft"]
%>

<div class="container py-4" style="max-width: 1000px;">
  <%= link_to "← Retour au projet", project_path(@project),
        style: "color: #9B9588; text-decoration: none; font-size: 0.9rem;" %>

  <div class="d-flex justify-content-between align-items-start mt-3 mb-4 flex-wrap gap-2">
    <div>
      <h2 class="mb-1" style="font-weight: 700; color: #2C2A25;">Suivi des devis artisans</h2>
      <div style="color: #9B9588; font-size: 0.9rem;">
        Niveau : <strong style="color: #2C2A25;"><%= @bidding_round.standing_label %></strong>
        · Date limite : <strong style="color: #2C2A25;"><%= l(@bidding_round.deadline, format: :short) %></strong>
      </div>
    </div>
    <div class="d-flex align-items-center gap-2">
      <span class="br-status-badge <%= sc %>"><%= sl %></span>
      <% if @bidding_round.ready_for_review? %>
        <%= link_to "Voir les recommandations →",
              review_responses_project_bidding_round_path(@project),
              class: "btn btn-dark-od btn-sm" %>
      <% end %>
    </div>
  </div>

  <%# Progress card %>
  <div class="progress-card">
    <div class="row g-3 text-center">
      <div class="col-4">
        <div style="font-size: 1.8rem; font-weight: 700; color: #2C2A25;">
          <%= @bidding_round.total_requests %>
        </div>
        <div style="font-size: 0.8rem; color: #9B9588;">Demandes envoyées</div>
      </div>
      <div class="col-4">
        <div style="font-size: 1.8rem; font-weight: 700; color: #2D6A4F;">
          <%= @bidding_round.responses_received %>
        </div>
        <div style="font-size: 0.8rem; color: #9B9588;">Réponses reçues</div>
      </div>
      <div class="col-4">
        <div style="font-size: 1.8rem; font-weight: 700; color: #2C2A25;">
          <% days_left = [(@bidding_round.deadline.to_date - Date.current).to_i, 0].max %>
          <%= days_left %>j
        </div>
        <div style="font-size: 0.8rem; color: #9B9588;">Jours restants</div>
      </div>
    </div>
    <% if @bidding_round.total_requests > 0 %>
      <div class="mt-3">
        <div style="font-size: 0.8rem; color: #9B9588; margin-bottom: 6px;">
          Avancement : <%= @bidding_round.responses_received %> / <%= @bidding_round.total_requests %> réponses
        </div>
        <div style="background: #E8E4DC; border-radius: 4px; height: 6px;">
          <div style="background: #2C2A25; border-radius: 4px; height: 6px; width: <%= [(@bidding_round.responses_received.to_f / @bidding_round.total_requests * 100).round, 100].min %>%;"></div>
        </div>
      </div>
    <% end %>
  </div>

  <%# Requests by category %>
  <% if @requests_by_category.any? %>
    <div style="font-weight: 700; color: #2C2A25; margin-bottom: 12px;">Par catégorie</div>
    <% @requests_by_category.each do |category, requests| %>
      <div class="cat-group">
        <div class="cat-group-header">
          <%= category&.name || "Autre" %>
          <span style="color: #9B9588; font-weight: 400; font-size: 0.85rem; margin-left: 8px;">
            <%= requests.count %> artisan<%= requests.count > 1 ? "s" : "" %>
          </span>
        </div>
        <% requests.each do |req| %>
          <% rl, rc = req_labels[req.status] || ["?", "req-pending"] %>
          <div class="artisan-row">
            <div class="d-flex align-items-center gap-3">
              <div class="artisan-avatar-sm"><%= req.artisan.name.first.upcase %></div>
              <div>
                <div style="font-weight: 600; color: #2C2A25; font-size: 0.9rem;"><%= req.artisan.name %></div>
                <div style="font-size: 0.8rem; color: #9B9588;">
                  <%= req.artisan.company_name.presence || req.artisan.postcode %>
                  <% if req.artisan.rating.present? %>
                    · ★ <%= req.artisan.star_rating %>
                  <% end %>
                </div>
              </div>
            </div>
            <div class="d-flex align-items-center gap-3">
              <% if req.responded? && req.price_total.present? %>
                <div style="font-weight: 700; color: #2C2A25;">
                  <%= number_to_currency(req.price_total, unit: "€", format: "%n %u", precision: 0) %> HT
                </div>
              <% end %>
              <span class="req-status-badge <%= rc %>"><%= rl %></span>
              <% if req.responded_at.present? %>
                <span style="font-size: 0.75rem; color: #9B9588;">
                  <%= l(req.responded_at, format: :short) %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5" style="border: 1px solid #E8E4DC; border-radius: 10px; background: #fff;">
      <div style="color: #9B9588; font-size: 0.9rem;">Aucune demande envoyée pour l'instant.</div>
    </div>
  <% end %>
</div>
