<% content_for :head do %>
<style>
  .artisan-card {
    border: 2px solid #E8E4DC;
    border-radius: 10px;
    padding: 14px 16px;
    cursor: pointer;
    transition: all 0.15s ease;
    background: #fff;
    position: relative;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .artisan-card:hover { border-color: #9B9588; }
  .artisan-card.selected { border-color: #2C2A25; background: #F5F3EE; }
  .artisan-card.disabled { opacity: 0.4; cursor: not-allowed; }
  .artisan-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: #2C2A25; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.9rem; flex-shrink: 0;
  }
  .artisan-name { font-weight: 600; font-size: 0.9rem; color: #2C2A25; }
  .artisan-meta { font-size: 0.8rem; color: #9B9588; }
  .artisan-rating { font-size: 0.85rem; color: #2C2A25; font-weight: 600; }
  .artisan-checkbox { position: absolute; top: 14px; right: 14px; accent-color: #2C2A25; width: 16px; height: 16px; }
  .cat-section { border: 1px solid #E8E4DC; border-radius: 10px; background: #fff; margin-bottom: 20px; overflow: hidden; }
  .cat-section-header {
    padding: 14px 20px;
    background: #FAFAF7;
    border-bottom: 1px solid #E8E4DC;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .cat-section-body { padding: 16px 20px; }
  .selection-counter { font-size: 0.8rem; color: #9B9588; }
  .selection-counter.has-selection { color: #2D6A4F; font-weight: 600; }
</style>
<% end %>

<div class="container py-4" style="max-width: 860px;">
  <%= link_to "← Retour", new_project_bidding_round_path(@project),
        style: "color: #9B9588; text-decoration: none; font-size: 0.9rem;" %>

  <h2 class="mt-3 mb-1" style="font-weight: 700; color: #2C2A25;">Choisir les artisans</h2>
  <p class="mb-4" style="color: #9B9588;">Sélectionnez jusqu'à 3 artisans par catégorie. Ils recevront une demande de devis.</p>

  <%= form_with url: update_artisans_project_bidding_round_path(@project), method: :patch,
        data: { controller: "artisan-select" } do |f| %>

    <% if @categories.any? %>
      <% @categories.each do |category| %>
        <% artisans = @artisans_by_category[category.id] || [] %>
        <div class="cat-section" data-artisan-select-target="section" data-max="3">
          <div class="cat-section-header">
            <div>
              <span style="font-weight: 700; color: #2C2A25;"><%= category.name %></span>
              <span style="color: #9B9588; font-size: 0.85rem; margin-left: 8px;">
                (<%= artisans.count %> artisans disponibles)
              </span>
            </div>
            <span class="selection-counter" data-artisan-select-target="counter">
              0 / 3 sélectionnés
            </span>
          </div>
          <div class="cat-section-body">
            <% if artisans.any? %>
              <% artisans.each do |artisan| %>
                <label class="artisan-card" data-artisan-select-target="card">
                  <input type="checkbox"
                         name="artisan_selections[<%= category.id %>][]"
                         value="<%= artisan.id %>"
                         class="artisan-checkbox"
                         data-artisan-select-target="checkbox"
                         data-action="change->artisan-select#toggle">
                  <div class="artisan-avatar">
                    <%= artisan.name.first.upcase %>
                  </div>
                  <div style="flex: 1; min-width: 0;">
                    <div class="artisan-name"><%= artisan.name %></div>
                    <div class="artisan-meta">
                      <%= artisan.company_name.presence || artisan.postcode %>
                      <% if artisan.company_name.present? %>
                        · <%= artisan.postcode %>
                      <% end %>
                    </div>
                  </div>
                  <div class="text-end">
                    <% if artisan.rating.present? %>
                      <div class="artisan-rating">★ <%= artisan.star_rating %></div>
                    <% end %>
                    <% if artisan.certifications.present? %>
                      <div class="artisan-meta">Certifié</div>
                    <% end %>
                  </div>
                </label>
              <% end %>
            <% else %>
              <div style="color: #9B9588; font-size: 0.9rem; text-align: center; padding: 20px 0;">
                Aucun artisan disponible dans ce secteur pour cette catégorie.
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5" style="border: 1px solid #E8E4DC; border-radius: 10px; background: #fff;">
        <div style="color: #9B9588;">Aucune catégorie sélectionnée.</div>
        <%= link_to "← Retour", new_project_bidding_round_path(@project), class: "btn btn-ghost-od btn-sm mt-3" %>
      </div>
    <% end %>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to "← Retour", new_project_bidding_round_path(@project),
            style: "color: #9B9588; text-decoration: none;" %>
      <button type="submit"
              style="background: #2C2A25; color: #fff; border: none; padding: 10px 24px; border-radius: 8px;
                     font-weight: 600; cursor: pointer;">
        Envoyer les demandes →
      </button>
    </div>
  <% end %>
</div>
