<% content_for :head do %>
<style>
  .bd-cat-card {
    border: 2px solid #C8C4BC;
    border-radius: 10px;
    padding: 16px;
    cursor: pointer;
    transition: all 0.15s ease;
    background: #fff;
    position: relative;
    user-select: none;
  }
  .bd-cat-card:hover { border-color: #4A4640; }
  .bd-cat-card.selected {
    border-color: #2C2A25;
    background: #F5F3EE;
  }
  .bd-cat-checkbox { position: absolute; top: 12px; right: 12px; accent-color: #2C2A25; width: 16px; height: 16px; }
  .bd-cat-name { font-weight: 600; font-size: 0.9rem; color: #2C2A25; margin-top: 4px; }
  .bd-cat-meta { font-size: 0.8rem; color: #4A4640; margin-top: 2px; }
  .bd-cat-price { font-size: 0.95rem; font-weight: 700; color: #2C2A25; margin-top: 6px; }
  .info-card { background: #F5F3EE; border: 1px solid #C8C4BC; border-radius: 10px; padding: 16px 20px; }
</style>
<% end %>

<div class="container py-4" style="max-width: 860px;">
  <%= link_to "← Retour au projet", project_path(@project),
        style: "color: #4A4640; text-decoration: none; font-size: 0.9rem;" %>

  <h2 class="mt-3 mb-1" style="font-weight: 700; color: #2C2A25;">Demander des devis artisans</h2>
  <p class="mb-4" style="color: #4A4640;">Sélectionnez les catégories et la date limite pour recevoir des propositions.</p>

  <div class="info-card mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <span style="font-weight: 600; color: #2C2A25;">Niveau sélectionné : <%= BiddingRound::STANDING_LABELS[@standing_level] %></span>
        <% total_ht = @categories_with_items.sum { |c| c.subtotal_ht.to_f } %>
        <div style="color: #4A4640; font-size: 0.9rem;">
          Estimation initiale : <%= number_to_currency(total_ht, unit: "€", format: "%n %u", precision: 0) %> HT
        </div>
      </div>
    </div>
  </div>

  <%= form_with url: project_bidding_round_path(@project), method: :post,
        data: { controller: "bidding-step1" } do |f| %>
    <input type="hidden" name="bidding_round[standing_level]" value="<%= @standing_level %>">

    <h5 class="mb-1" style="font-weight: 700; color: #2C2A25;">Catégories à envoyer</h5>
    <p class="mb-3" style="color: #4A4640; font-size: 0.9rem;">
      Sélectionnez les catégories pour lesquelles vous souhaitez recevoir des devis artisans.
    </p>

    <% if @categories_with_items.any? %>
      <div class="row g-3 mb-4">
        <% @categories_with_items.each do |category| %>
          <div class="col-md-4">
            <label class="bd-cat-card w-100 d-block" data-bidding-step1-target="catCard">
              <input type="checkbox" name="category_ids[]" value="<%= category.id %>"
                     class="bd-cat-checkbox"
                     data-action="change->bidding-step1#updateButton">
              <div class="bd-cat-name"><%= category.name %></div>
              <div class="bd-cat-meta"><%= category.items_count %> postes</div>
              <div class="bd-cat-price">
                <%= number_to_currency(category.subtotal_ht.to_f, unit: "€", format: "%n %u", precision: 0) %> HT
              </div>
            </label>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4 mb-4" style="border: 1px solid #C8C4BC; border-radius: 10px; background: #fff;">
        <div style="color: #4A4640; font-size: 0.9rem;">
          Aucun poste au niveau <%= BiddingRound::STANDING_LABELS[@standing_level] %> pour ce projet.
          <br><%= link_to "Retour au projet", project_path(@project) %> pour ajouter des postes.
        </div>
      </div>
    <% end %>

    <h5 class="mb-2" style="font-weight: 700; color: #2C2A25;">Date limite de réponse</h5>
    <p class="mb-2" style="color: #4A4640; font-size: 0.9rem;">Les artisans auront jusqu'à cette date pour répondre.</p>

    <div class="row g-2 mb-1">
      <div class="col-auto">
        <% default_deadline = 7.days.from_now.strftime("%Y-%m-%dT%H:%M") %>
        <input type="datetime-local"
               name="bidding_round[deadline]"
               value="<%= default_deadline %>"
               min="<%= 24.hours.from_now.strftime("%Y-%m-%dT%H:%M") %>"
               class="form-control"
               style="border: 1.5px solid #C8C4BC; border-radius: 8px;"
               data-bidding-step1-target="deadline"
               data-action="change->bidding-step1#updateButton">
      </div>
    </div>
    <p class="mb-4" style="color: #4A4640; font-size: 0.8rem;">Recommandé : 7 jours.</p>

    <div class="d-flex justify-content-between align-items-center">
      <%= link_to "← Retour", project_path(@project),
            style: "color: #4A4640; text-decoration: none;" %>
      <button type="submit"
              data-bidding-step1-target="submitBtn"
              disabled
              style="background: #2C2A25; color: #fff; border: none; padding: 10px 24px; border-radius: 8px;
                     font-weight: 600; cursor: pointer; opacity: 0.4; transition: opacity 0.15s;">
        Choisir les artisans →
      </button>
    </div>
  <% end %>
</div>
