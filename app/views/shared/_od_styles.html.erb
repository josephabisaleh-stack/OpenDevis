/* ─── Design system globals ───────────────────────────────────── */
body { background-color: #FFFFFF; }

/* Buttons */
.btn-dark-od {
  background-color: #2663EB; border: 1.5px solid #2663EB; color: #fff;
  border-radius: 50px; font-weight: 600; padding: 0.65rem 1.8rem;
  font-size: 0.95rem; letter-spacing: 0.01em;
  display: inline-flex; align-items: center; gap: 0.45rem;
  transition: background-color 0.2s, border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}
.btn-dark-od:hover {
  background-color: #1B4FC2; border-color: #1B4FC2; color: #fff;
  transform: translateY(-2px); box-shadow: 0 4px 14px rgba(38,99,235,0.30);
}
.btn-dark-od:active { transform: translateY(0); box-shadow: 0 1px 4px rgba(38,99,235,0.2); }
.btn-dark-od:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

.btn-ghost-od {
  background: transparent; border: 1.5px solid #C8C4BC; color: #4A4640;
  border-radius: 50px; font-weight: 500; padding: 0.65rem 1.8rem;
  font-size: 0.95rem;
  display: inline-flex; align-items: center; gap: 0.45rem;
  transition: border-color 0.2s, color 0.2s, background-color 0.2s, transform 0.2s, box-shadow 0.2s;
}
.btn-ghost-od:hover {
  border-color: #2563eb; color: #fff; background: #2563eb;
  transform: translateY(-2px); box-shadow: 0 4px 14px rgba(37,99,235,0.30);
}
.btn-ghost-od:active { transform: translateY(0); box-shadow: 0 1px 4px rgba(37,99,235,0.2); }

/* Override Bootstrap's btn-primary & btn-outline-secondary everywhere */
.btn-primary, .btn.btn-primary {
  background-color: #2C2A25 !important; border-color: #2C2A25 !important; border-radius: 8px;
}
.btn-primary:hover { background-color: #1a1916 !important; border-color: #1a1916 !important; }

.btn-outline-secondary, .btn.btn-outline-secondary {
  border-color: #9B9588 !important; color: #4A4640 !important; border-radius: 8px;
}
.btn-outline-secondary:hover { border-color: #2C2A25 !important; color: #2C2A25 !important; }

/* Status badges */
.badge-brouillon { background-color: #D8D4CA; color: #3A3830; }
.badge-en-cours  { background-color: #A8D5B5; color: #1A4D30; }
.badge-termine   { background-color: #A0CCE8; color: #0D3D5C; }
.badge-refuse    { background-color: #F0B8BC; color: #6B1018; }

/* Cards */
.od-card {
  border: 1.5px solid #C8C4BC; border-radius: 10px; background: #fff;
  transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  box-shadow: 0 1px 4px rgba(44,42,37,0.08);
}
.od-card:hover {
  border-color: #2C2A25; transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(44,42,37,0.18);
}

/* Form inputs */
.form-control, .form-select {
  border-color: #C8C4BC; border-radius: 8px; font-size: 0.95rem;
}
.form-control:focus, .form-select:focus {
  border-color: #2C2A25; box-shadow: 0 0 0 2px rgba(44,42,37,0.2);
}
label, .form-label, .col-form-label { font-size: 0.85rem; font-weight: 600; color: #2C2A25; }
.form-text, .hint { font-size: 0.78rem; color: #6B6560; }

/* Form page layout */
.od-form-card {
  background: #fff; border: 1.5px solid #C8C4BC; border-radius: 10px; padding: 1.75rem 2rem;
  box-shadow: 0 2px 8px rgba(44,42,37,0.08);
}
.od-page-title { font-size: 1.3rem; font-weight: 700; color: #2C2A25; margin-bottom: 1.5rem; }
.od-back-link {
  color: #6B6560; font-size: 0.85rem; text-decoration: none; display: inline-block; margin-bottom: 1rem;
}
.od-back-link:hover { color: #2C2A25; }

/* Tables */
.od-table { border-collapse: collapse; width: 100%; }
.od-table thead th {
  font-size: 0.78rem; font-weight: 700; color: #6B6560; text-transform: uppercase;
  letter-spacing: 0.04em; border-bottom: 2px solid #C8C4BC; padding: 0.6rem 0.75rem;
  background: #F0EEE9;
}
.od-table tbody td {
  font-size: 0.9rem; color: #2C2A25; padding: 0.75rem; border-bottom: 1px solid #E0DCD4;
  vertical-align: middle;
}
.od-table tbody tr:last-child td { border-bottom: none; }
.od-table tbody tr:hover td { background: #EDEAE4; }
.od-table-wrap { border: 1.5px solid #C8C4BC; border-radius: 10px; overflow: hidden; }

/* Flashes */
.od-flash {
  margin: 0.5rem 1rem;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  font-size: 0.9rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.od-flash-notice { background: #A8D5B5; color: #1A4D30; border: 2px solid #7ABF90; }
.od-flash-alert  { background: #FFE8A0; color: #6B4D00; border: 2px solid #F0C830; }

/* Wizard stepper */
.wizard-stepper { gap: 0; }
.wizard-step { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.step-circle {
  width: 34px; height: 34px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem; font-weight: 600;
  border: 2px solid #9B9588; background: #fff; color: #6B6560;
  transition: all 0.2s ease;
}
.wizard-step.active .step-circle { border-color: #2C2A25; background: #2C2A25; color: #fff; }
.wizard-step.done .step-circle   { border-color: #2663EB; background: #2663EB; color: #fff; }
.step-label { font-size: 0.75rem; color: #6B6560; white-space: nowrap; transition: color 0.2s ease; }
.wizard-step.active .step-label  { color: #2C2A25; font-weight: 600; }
.wizard-step.done .step-label    { color: #2663EB; font-weight: 500; }
.wizard-step-link { text-decoration: none; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.wizard-step-link:hover .step-circle { background: #1B4FC2; border-color: #1B4FC2; transform: scale(1.1); }
.wizard-step-link:hover .step-label  { color: #1B4FC2; }
.wizard-connector {
  height: 2px; width: 60px; background: #C8C4BC; margin: 0 8px; margin-bottom: 14px;
  transition: background 0.2s ease;
}
.wizard-connector.done { background: #2663EB; }
