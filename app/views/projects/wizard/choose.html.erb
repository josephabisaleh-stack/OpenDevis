<% content_for :head do %>
<style>
  body { background-color: #FFFFFF; }

  .choose-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    height: 96px;
    border: 2px solid #C8C4BC;
    border-radius: 12px;
    background: #fff;
    padding: 1.5rem 1.75rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, transform 0.15s, box-shadow 0.15s;
    text-align: left;
  }
  .choose-card:hover {
    border-color: #2C2A25;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(44,42,37,0.08);
  }
  .choose-icon {
    font-size: 2.5rem;
    line-height: 1;
    width: 3.5rem;
    text-align: center;
    flex-shrink: 0;
  }
  .choose-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #2C2A25;
    margin-bottom: 0.25rem;
  }
  .choose-desc {
    font-size: 0.88rem;
    color: #4A4640;
    line-height: 1.4;
  }

  .sub-choose-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    border: 1.5px solid #C8C4BC;
    border-radius: 10px;
    background: #FFFFFF;
    padding: 1rem 1.25rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: left;
    font-size: 0.92rem;
  }
  .sub-choose-card:hover {
    border-color: #2C2A25;
    background: #F0EDE8;
  }
  .sub-choose-icon {
    font-size: 1.5rem;
    width: 2rem;
    text-align: center;
    flex-shrink: 0;
  }
  .sub-choose-title {
    font-weight: 600;
    color: #2C2A25;
  }
  .sub-choose-desc {
    font-size: 0.82rem;
    color: #4A4640;
  }

</style>
<% end %>

<div class="container py-5" style="max-width: 580px;">
  <div class="text-center mb-4">
    <h2 style="color: #2C2A25; font-weight: 700; font-size: 1.6rem;">Nouveau projet</h2>
    <p style="color: #4A4640;">Quel type de projet souhaitez-vous estimer ?</p>
  </div>

  <div class="d-flex flex-column gap-3">
    <%# Rénovation %>
    <%= form_with url: wizard_save_choose_path, method: :post, html: { class: "w-100" } do %>
      <input type="hidden" name="project_type" value="renovation">
      <button type="submit" class="choose-card">
        <div class="choose-icon">🔧</div>
        <div>
          <div class="choose-title">Rénovation</div>
          <div class="choose-desc">Rénovation partielle, complète ou énergétique</div>
        </div>
      </button>
    <% end %>

    <%# Construction neuve %>
    <%= form_with url: wizard_save_choose_path, method: :post, html: { class: "w-100" } do %>
      <input type="hidden" name="project_type" value="construction">
      <button type="submit" class="choose-card">
        <div class="choose-icon">🏠</div>
        <div>
          <div class="choose-title">Construction neuve</div>
          <div class="choose-desc">Maison, véranda…</div>
        </div>
      </button>
    <% end %>
  </div>

  <div class="text-center mt-4">
    <%= link_to "← Retour aux projets", projects_path, style: "color: #4A4640; font-size: 0.9rem;" %>
  </div>
</div>
