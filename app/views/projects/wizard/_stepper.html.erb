<%
project_type = local_assigns[:project_type] || "renovation"

if project_type == "construction"
  step_paths = {
    1 => wizard_step1_path,
    2 => wizard_step2_path,
    3 => wizard_step4_path
  }
  steps = [
    [1, "Votre idée"],
    [2, "+ d'info"],
    [3, "Récapitulatif"]
  ]
elsif project_type == "extension"
  step_paths = {
    1 => wizard_step1_path,
    3 => wizard_step3_path,
    4 => wizard_step4_path
  }
  steps = [
    [1, "Le bien existant"],
    [3, "Détails des travaux"],
    [4, "Récapitulatif"]
  ]
else
  step_paths = {
    1 => wizard_step1_path,
    2 => wizard_step2_path,
    3 => wizard_step3_path,
    4 => wizard_step4_path
  }
  steps = [
    [1, "Le bien existant"],
    [2, "Type de rénovation"],
    [3, "Détails des travaux"],
    [4, "Récapitulatif"]
  ]
end
%>

<div class="d-flex justify-content-center align-items-center mb-5 wizard-stepper">
  <% steps.each_with_index do |(num, label), idx| %>
    <%
      state = if num == current_step
               "active"
             elsif num < current_step
               "done"
             else
               "pending"
             end
    %>
    <div class="wizard-step <%= state %>">
      <% if state == "done" %>
        <%= link_to step_paths[num], class: "wizard-step-link" do %>
          <div class="step-circle"><%= num %></div>
          <div class="step-label d-none d-sm-block"><%= label %></div>
        <% end %>
      <% else %>
        <div class="step-circle"><%= num %></div>
        <div class="step-label d-none d-sm-block"><%= label %></div>
      <% end %>
    </div>
    <% if idx < steps.length - 1 %>
      <div class="wizard-connector <%= num < current_step ? 'done' : '' %>"></div>
    <% end %>
  <% end %>
</div>
