<% content_for :head do %>
<style>
  .import-mode-btn {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    background: #fff;
    padding: 1rem 1.4rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: center;
    font-size: 0.9rem;
    color: #2C2A25;
  }
  .import-mode-btn:hover { border-color: #2C2A25; }
  .import-mode-btn.active { border-color: #2C2A25; background: #F0EDE8; }

  .import-panel {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    background: #FFFFFF;
    padding: 1.25rem;
    margin-top: 0.75rem;
  }

  .field-section {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    padding: 1.5rem;
    background: #fff;
  }
  .field-label { font-size: 0.85rem; font-weight: 600; color: #2C2A25; margin-bottom: 0.3rem; }
  .field-label .required { color: #C25E4A; margin-left: 2px; }
  .form-control, .form-select {
    border-color: #C8C4BC;
    border-radius: 8px;
    font-size: 0.95rem;
  }
  .form-control:focus, .form-select:focus {
    border-color: #2C2A25;
    box-shadow: 0 0 0 2px rgba(44,42,37,0.1);
  }

  /* Property type radio cards */
  .property-type-options { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .property-type-option {
    flex: 1;
    min-width: 120px;
  }
  .property-type-option input[type="radio"] { display: none; }
  .property-type-option label {
    display: block;
    text-align: center;
    padding: 0.65rem 0.75rem;
    border: 1.5px solid #C8C4BC;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    color: #2C2A25;
    transition: border-color 0.15s, background 0.15s;
  }
  .property-type-option label:hover { border-color: #2C2A25; }
  .property-type-option input:checked + label {
    border-color: #2C2A25;
    background: #F0EDE8;
    font-weight: 600;
  }

  /* City autocomplete */
  .autocomplete-wrapper { position: relative; }
  .autocomplete-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 10;
    background: #fff;
    border: 1px solid #C8C4BC;
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(44,42,37,0.1);
    margin-top: 4px;
    max-height: 220px;
    overflow-y: auto;
  }
  .autocomplete-item {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    text-align: left;
    font-size: 0.9rem;
    color: #2C2A25;
    cursor: pointer;
  }
  .autocomplete-item:hover { background: #F0EDE8; }

  .field-error {
    font-size: 0.8rem;
    color: #C25E4A;
    margin-top: 0.25rem;
  }
  .chat-messages {
    max-height: 200px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .chat-msg {
    padding: 0.5rem 0.75rem;
    border-radius: 10px;
    font-size: 0.9rem;
    max-width: 85%;
    line-height: 1.4;
    word-break: break-word;
  }
  .chat-msg--user      { background: #2C2A25; color: #fff; align-self: flex-end; }
  .chat-msg--assistant { background: #F0EDE8; color: #2C2A25; align-self: flex-start; }
  .mic-btn {
    border: 1px solid #C8C4BC; border-left: 0; border-radius: 0 8px 8px 0;
    background: #fff; color: #4A4640; display: flex; align-items: center; justify-content: center;
    width: 40px; transition: background 0.15s, color 0.15s;
  }
  .mic-btn:hover { background: #F0EDE8; color: #2C2A25; }
  .mic-btn canvas { display: block; }
  .chat-input {
    resize: none; overflow: hidden;
    min-height: 38px; max-height: 120px;
    border-radius: 8px 0 0 8px; line-height: 1.5;
  }
  .btn-send-chat {
    border: 1px solid #C8C4BC; border-radius: 8px;
    background: #fff; color: #4A4640;
    padding: 0.375rem 0.85rem; font-size: 0.9rem; font-weight: 500;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    cursor: default; white-space: nowrap;
  }
  .btn-send-chat.active {
    background: #2C2A25; color: #fff; border-color: #2C2A25; cursor: pointer;
  }
  .pdf-dropzone {
    border: 2px dashed #C8C4BC;
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    color: #4A4640;
  }
  .pdf-dropzone:hover, .pdf-dropzone.dragover {
    border-color: #2C2A25;
    background: #F0EDE8;
  }
  .pdf-dropzone .upload-icon { font-size: 1.8rem; margin-bottom: 0.4rem; }

  /* Pulse fallback when getUserMedia is denied */
  .mic-btn canvas[data-pulse="true"] {
    animation: waveform-pulse 0.8s ease-in-out infinite alternate;
  }
  @keyframes waveform-pulse {
    from { opacity: 0.3; transform: scaleY(0.5); }
    to   { opacity: 1;   transform: scaleY(1); }
  }
</style>
<% end %>

<%
  # Extract property type from property_url for pre-filling
  property_type_value = case @project.property_url
                        when "appartement", "maison" then @project.property_url
                        when nil, "" then nil
                        else "autre"
                        end
  property_type_autre = property_type_value == "autre" ? @project.property_url : ""
%>

<div class="container py-4" style="max-width: 680px;">
  <%= render "stepper", current_step: 1, project_type: @project_type %>

  <% if @project_type.in?(%w[construction extension]) %>
    <h2 class="mb-1" style="color: #2C2A25; font-weight: 700;">Décrivez le bien souhaité</h2>
    <p class="mb-4" style="color: #4A4640;">Renseignez les caractéristiques de votre futur bien.</p>
  <% else %>
    <h2 class="mb-1" style="color: #2C2A25; font-weight: 700;">Décrivez le bien</h2>
    <p class="mb-4" style="color: #4A4640;">Importez les infos ou remplissez manuellement.</p>
  <% end %>

  <%# Import modes %>
  <div class="mb-4" data-controller="import-mode">
    <div class="small fw-semibold mb-2" style="color: #4A4640;">Importer automatiquement <span class="fw-normal">(facultatif)</span></div>
    <div class="d-flex gap-2 mb-2">
      <button type="button" class="import-mode-btn flex-fill"
              data-import-mode-target="btn"
              data-action="click->import-mode#toggle"
              data-mode="url">
        🔗<br>URL d'annonce
      </button>
      <button type="button" class="import-mode-btn flex-fill"
              data-import-mode-target="btn"
              data-action="click->import-mode#toggle"
              data-mode="pdf">
        📄<br>PDF / Document
      </button>
      <button type="button" class="import-mode-btn flex-fill"
              data-import-mode-target="btn"
              data-action="click->import-mode#toggle"
              data-mode="chat">
        💬<br>Chat IA
      </button>
    </div>

    <div data-import-mode-target="panel" data-mode="url" hidden class="import-panel"
         data-controller="url-analyze"
         data-url-analyze-endpoint-value="<%= wizard_analyze_url_path %>">
      <div class="d-flex gap-2">
        <input type="text" class="form-control" placeholder="https://www.seloger.com/annonces/..."
               data-url-analyze-target="input">
        <button class="btn btn-outline-secondary" type="button"
                data-action="click->url-analyze#analyze"
                data-url-analyze-target="btn">
          Analyser ✨
        </button>
      </div>
      <div data-url-analyze-target="status" hidden></div>
    </div>

    <div data-import-mode-target="panel" data-mode="pdf" hidden class="import-panel"
         data-controller="pdf-upload"
         data-pdf-upload-endpoint-value="<%= wizard_analyze_pdf_path %>">

      <div class="pdf-dropzone"
           data-pdf-upload-target="dropzone"
           data-action="dragover->pdf-upload#dragover dragleave->pdf-upload#dragleave drop->pdf-upload#drop click->pdf-upload#openPicker">
        <div class="upload-icon">📄</div>
        <div class="fw-semibold" style="font-size: 0.9rem; color: #2C2A25;">Glissez votre PDF ici</div>
        <div style="font-size: 0.8rem; margin-top: 0.2rem;">
          ou <span style="text-decoration: underline;">cliquez pour choisir un fichier</span>
        </div>
        <div style="font-size: 0.75rem; color: #4A4640; margin-top: 0.3rem;">PDF uniquement · max 10 Mo</div>
      </div>

      <input type="file" accept=".pdf,application/pdf"
             data-pdf-upload-target="fileInput"
             data-action="change->pdf-upload#fileSelected"
             hidden>

      <%# Filename + red X — visible only when a file is selected %>
      <div class="d-flex align-items-center gap-1 mt-2 overflow-hidden" style="min-height: 22px; display: none !important;"
           data-pdf-upload-target="fileRow">
        <span data-pdf-upload-target="filename"
              class="small text-muted text-truncate" style="max-width: 220px;"></span>
        <button type="button" class="btn p-0 lh-1" style="color: #dc3545; font-size: 1.1rem; flex-shrink: 0;"
                data-action="click->pdf-upload#remove"
                title="Retirer le fichier">
          &times;
        </button>
      </div>

      <%# Analyser button — always visible, disabled until a file is selected %>
      <div class="mt-2">
        <button type="button" disabled
                style="border-radius: 8px; padding: 0.35rem 0.85rem; font-size: 0.9rem; font-weight: 500; white-space: nowrap; background: #C8C4BC; color: #4A4640; border: 1px solid #C8C4BC; cursor: not-allowed;"
                data-pdf-upload-target="analyzeBtn"
                data-action="click->pdf-upload#analyze">
          Analyser ✨
        </button>
      </div>

      <div data-pdf-upload-target="status" hidden></div>
    </div>

    <div data-import-mode-target="panel" data-mode="chat" hidden class="import-panel"
         data-controller="chat-property"
         data-chat-property-endpoint-value="<%= wizard_chat_property_path %>">
      <div data-chat-property-target="messages" class="chat-messages"></div>
      <div class="input-group">
        <textarea class="form-control chat-input" rows="1"
                  placeholder="Décrivez votre bien en quelques mots..."
                  data-chat-property-target="input"
                  data-action="keydown->chat-property#handleKeydown input->chat-property#inputChanged"></textarea>
        <button type="button" class="mic-btn"
                data-chat-property-target="micBtn"
                data-action="click->chat-property#toggleMic"
                title="Dicter">
          <span data-chat-property-target="micIcon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none">
              <rect x="9" y="2" width="6" height="11" rx="3" fill="currentColor"/>
              <path d="M5 11a7 7 0 0 0 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
              <line x1="12" y1="18" x2="12" y2="22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <line x1="8"  y1="22" x2="16" y2="22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </span>
          <canvas data-chat-property-target="waveform"
                  width="34" height="24" hidden></canvas>
        </button>
        <button type="button" class="btn-send-chat ms-1"
                data-chat-property-target="sendBtn"
                data-action="click->chat-property#send">
          Envoyer
        </button>
      </div>
    </div>
  </div>

  <%# Manual fields %>
  <%= form_with model: @project, url: wizard_step1_path, method: :post,
      data: { controller: "wizard-form", action: "input->wizard-form#validate change->wizard-form#validate" } do |f| %>
    <div class="field-section">
      <div class="small fw-semibold mb-3" style="color: #4A4640;">
        Informations du bien
      </div>

      <div class="row g-3">
        <%# Titre du projet — optional %>
        <div class="col-12">
          <div class="field-label">Titre du projet</div>
          <%= f.text_field :name, class: "form-control", placeholder: "ex. Rénovation appartement Montmartre" %>
        </div>

        <%# Type de bien — required, radio cards (hidden for construction flow) %>
        <% unless @project_type == "construction" %>
        <div class="col-12" data-controller="property-type">
          <div class="field-label">Type de bien <span class="required">*</span></div>
          <div class="property-type-options">
            <div class="property-type-option">
              <input type="radio" name="project[property_type]" id="property_type_appartement" value="appartement"
                     data-required="true" data-action="change->property-type#toggle change->wizard-form#validate"
                     <%= "checked" if property_type_value == "appartement" %>>
              <label for="property_type_appartement">Appartement</label>
            </div>
            <div class="property-type-option">
              <input type="radio" name="project[property_type]" id="property_type_maison" value="maison"
                     data-required="true" data-action="change->property-type#toggle change->wizard-form#validate"
                     <%= "checked" if property_type_value == "maison" %>>
              <label for="property_type_maison">Maison</label>
            </div>
            <div class="property-type-option">
              <input type="radio" name="project[property_type]" id="property_type_autre" value="autre"
                     data-required="true" data-action="change->property-type#toggle change->wizard-form#validate"
                     <%= "checked" if property_type_value == "autre" %>>
              <label for="property_type_autre">Autre</label>
            </div>
          </div>
          <div data-property-type-target="autreField" <%= "hidden" unless property_type_value == "autre" %> class="mt-2">
            <input type="text" name="project[property_type_autre]" class="form-control"
                   placeholder="Veuillez préciser..." value="<%= property_type_autre %>">
          </div>
          <% if @errors&.include?(:property_type) %>
            <div class="field-error">Ce champ est obligatoire</div>
          <% end %>
        </div>
        <% end %>

        <%# Surface — required %>
        <div class="col-md-6">
          <div class="field-label"><%= @project_type == "construction" ? "Surface souhaitée du bien (m²)" : "Surface actuelle du bien (m²)" %> <span class="required">*</span></div>
          <%= f.number_field :total_surface_sqm, class: "form-control", placeholder: "ex. 78", step: 0.5,
              min: 0, data: { required: true } %>
          <% if @errors&.include?(:total_surface_sqm) %>
            <div class="field-error">Ce champ est obligatoire</div>
          <% end %>
        </div>

        <%# Nombre de pièces — optional %>
        <div class="col-md-6">
          <div class="field-label">Nombre de pièces</div>
          <%= f.number_field :room_count, class: "form-control", placeholder: "ex. 4" %>
        </div>

        <%# Code postal — required, with autocomplete %>
        <div class="col-md-6" data-controller="city-autocomplete">
          <div class="field-label">Code postal <span class="required">*</span></div>
          <div class="autocomplete-wrapper">
            <input type="text" class="form-control"
                   placeholder="ex. 75001"
                   inputmode="numeric"
                   pattern="[0-9]*"
                   value="<%= @project.location_zip.present? ? @project.location_zip : '' %>"
                   data-city-autocomplete-target="input"
                   data-action="input->city-autocomplete#search input->city-autocomplete#filterDigits input->wizard-form#validate"
                   data-required="true"
                   autocomplete="off">
            <input type="hidden" name="project[location_zip]"
                   value="<%= @project.location_zip %>"
                   data-city-autocomplete-target="hidden"
                   data-required="true">
            <div data-city-autocomplete-target="results" hidden class="autocomplete-results"></div>
          </div>
          <% if @errors&.include?(:location_zip) %>
            <div class="field-error">Veuillez saisir un code postal et sélectionner une ville dans la liste</div>
          <% end %>
        </div>

        <%# DPE — optional %>
        <div class="col-md-6">
          <div class="field-label"><%= @project_type.in?(%w[construction extension]) ? "DPE souhaité" : "DPE / Classe énergétique" %></div>
          <%= f.select :energy_rating,
                options_for_select(%w[A B C D E F G].map { |r| [r, r] }, @project.energy_rating),
                { include_blank: "— Sélectionner —" },
                class: "form-select" %>
        </div>
      </div>
    </div>

    <%# Commentaire — optional %>
    <div class="field-section mt-3">
      <div class="field-label">Commentaire</div>
      <%= f.text_area :description, class: "form-control", rows: 3,
          placeholder: "Ajoutez des précisions sur votre projet..." %>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to "← Retour", wizard_choose_path, class: "btn btn-ghost-od" %>
      <%= f.submit "Suivant →", class: "btn btn-dark-od", data: { wizard_form_target: "submit" } %>
    </div>
  <% end %>
</div>
