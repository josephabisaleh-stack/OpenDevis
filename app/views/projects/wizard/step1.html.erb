<% content_for :head do %>
<style>


  .import-mode-btn {
    border: 1px solid #E8E4DC;
    border-radius: 10px;
    background: #fff;
    padding: 1rem 1.4rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: center;
    font-size: 0.9rem;
    color: #2C2A25;
  }
  .import-mode-btn:hover { border-color: #2C2A25; }
  .import-mode-btn.active { border-color: #2C2A25; background: #F0EDE8; }

  .import-panel {
    border: 1px solid #E8E4DC;
    border-radius: 10px;
    background: #FAFAF7;
    padding: 1.25rem;
    margin-top: 0.75rem;
  }

  .field-section {
    border: 1px solid #E8E4DC;
    border-radius: 10px;
    padding: 1.5rem;
    background: #fff;
  }
  .field-label { font-size: 0.85rem; font-weight: 600; color: #2C2A25; margin-bottom: 0.3rem; }
  .form-control, .form-select {
    border-color: #E8E4DC;
    border-radius: 8px;
    font-size: 0.95rem;
  }
  .form-control:focus, .form-select:focus {
    border-color: #2C2A25;
    box-shadow: 0 0 0 2px rgba(44,42,37,0.1);
  }

  .chat-messages {
    max-height: 200px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .chat-msg {
    padding: 0.5rem 0.75rem;
    border-radius: 10px;
    font-size: 0.9rem;
    max-width: 85%;
    line-height: 1.4;
    word-break: break-word;
  }
  .chat-msg--user      { background: #2C2A25; color: #fff; align-self: flex-end; }
  .chat-msg--assistant { background: #F0EDE8; color: #2C2A25; align-self: flex-start; }
  .mic-btn {
    border: 1px solid #E8E4DC; border-left: 0; border-radius: 0 8px 8px 0;
    background: #fff; color: #9B9588; display: flex; align-items: center; justify-content: center;
    width: 40px; transition: background 0.15s, color 0.15s;
  }
  .mic-btn:hover { background: #F0EDE8; color: #2C2A25; }
  .mic-btn canvas { display: block; }
  .chat-input {
    resize: none; overflow: hidden;
    min-height: 38px; max-height: 120px;
    border-radius: 8px 0 0 8px; line-height: 1.5;
  }
  .btn-send-chat {
    border: 1px solid #E8E4DC; border-radius: 8px;
    background: #fff; color: #9B9588;
    padding: 0.375rem 0.85rem; font-size: 0.9rem; font-weight: 500;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    cursor: default; white-space: nowrap;
  }
  .btn-send-chat.active {
    background: #2C2A25; color: #fff; border-color: #2C2A25; cursor: pointer;
  }
  /* Pulse fallback when getUserMedia is denied */
  .mic-btn canvas[data-pulse="true"] {
    animation: waveform-pulse 0.8s ease-in-out infinite alternate;
  }
  @keyframes waveform-pulse {
    from { opacity: 0.3; transform: scaleY(0.5); }
    to   { opacity: 1;   transform: scaleY(1); }
  }
</style>
<% end %>

<div class="container py-4" style="max-width: 680px;">
  <%= render "stepper", current_step: 1, project_type: @project_type %>

  <% if @project_type.in?(%w[construction extension]) %>
    <h2 class="mb-1" style="color: #2C2A25; font-weight: 700;">Décrivez le bien souhaité</h2>
    <p class="mb-4" style="color: #9B9588;">Renseignez les caractéristiques de votre futur bien.</p>
  <% else %>
    <h2 class="mb-1" style="color: #2C2A25; font-weight: 700;">Décrivez votre bien</h2>
    <p class="mb-4" style="color: #9B9588;">Importez les infos ou remplissez manuellement.</p>
  <% end %>

  <%# Import modes %>
  <div class="mb-4" data-controller="import-mode">
    <div class="small fw-semibold mb-2" style="color: #9B9588;">Importer automatiquement <span class="fw-normal">(facultatif)</span></div>
    <div class="d-flex gap-2 mb-2">
      <button type="button" class="import-mode-btn flex-fill"
              data-import-mode-target="btn"
              data-action="click->import-mode#toggle"
              data-mode="url">
        🔗<br>URL d'annonce
      </button>
      <button type="button" class="import-mode-btn flex-fill"
              data-import-mode-target="btn"
              data-action="click->import-mode#toggle"
              data-mode="pdf">
        📄<br>PDF / Document
      </button>
      <button type="button" class="import-mode-btn flex-fill"
              data-import-mode-target="btn"
              data-action="click->import-mode#toggle"
              data-mode="chat">
        💬<br>Chat IA
      </button>
    </div>

    <div data-import-mode-target="panel" data-mode="url" hidden class="import-panel"
         data-controller="url-analyze"
         data-url-analyze-endpoint-value="<%= wizard_analyze_url_path %>">
      <div class="d-flex gap-2">
        <input type="text" class="form-control" placeholder="https://www.seloger.com/annonces/..."
               data-url-analyze-target="input">
        <button class="btn btn-outline-secondary" type="button"
                data-action="click->url-analyze#analyze"
                data-url-analyze-target="btn">
          Analyser ✨
        </button>
      </div>
      <div data-url-analyze-target="status" hidden></div>
    </div>

    <div data-import-mode-target="panel" data-mode="pdf" hidden class="import-panel text-center py-3">
      <div style="color: #9B9588; font-size: 0.9rem;">
        📄 Déposez votre document ici<br>
        <span style="font-size: 0.8rem;">
          <% if @project_type.in?(%w[construction extension]) %>
            PLU, plans, etc.
          <% else %>
            Fonctionnalité IA à venir
          <% end %>
        </span>
      </div>
    </div>

    <div data-import-mode-target="panel" data-mode="chat" hidden class="import-panel"
         data-controller="chat-property"
         data-chat-property-endpoint-value="<%= wizard_chat_property_path %>">
      <div data-chat-property-target="messages" class="chat-messages"></div>
      <div class="input-group">
        <textarea class="form-control chat-input" rows="1"
                  placeholder="Décrivez votre bien en quelques mots..."
                  data-chat-property-target="input"
                  data-action="keydown->chat-property#handleKeydown input->chat-property#inputChanged"></textarea>
        <button type="button" class="mic-btn"
                data-chat-property-target="micBtn"
                data-action="click->chat-property#toggleMic"
                title="Dicter">
          <span data-chat-property-target="micIcon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none">
              <rect x="9" y="2" width="6" height="11" rx="3" fill="currentColor"/>
              <path d="M5 11a7 7 0 0 0 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
              <line x1="12" y1="18" x2="12" y2="22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <line x1="8"  y1="22" x2="16" y2="22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </span>
          <canvas data-chat-property-target="waveform"
                  width="34" height="24" hidden></canvas>
        </button>
        <button type="button" class="btn-send-chat ms-1"
                data-chat-property-target="sendBtn"
                data-action="click->chat-property#send">
          Envoyer
        </button>
      </div>
    </div>
  </div>

  <%# Manual fields %>
  <%= form_with model: @project, url: wizard_step1_path, method: :post do |f| %>
    <div class="field-section">
      <div class="small fw-semibold mb-3" style="color: #9B9588;">
        Informations du bien — <span class="fw-normal">tous facultatifs</span>
      </div>

      <div class="row g-3">
        <div class="col-12">
          <div class="field-label">Type de bien</div>
          <input type="text" id="project_property_url" name="project[property_url]" class="form-control"
                 placeholder="Appartement, maison, studio..."
                 value="<%= @project.property_url %>">
        </div>
        <div class="col-md-6">
          <div class="field-label">Surface totale (m²)</div>
          <%= f.number_field :total_surface_sqm, class: "form-control", placeholder: "ex. 78", step: 0.5 %>
        </div>
        <div class="col-md-6">
          <div class="field-label">Nombre de pièces</div>
          <%= f.number_field :room_count, class: "form-control", placeholder: "ex. 4" %>
        </div>
        <div class="col-md-6">
          <div class="field-label">Code postal</div>
          <%= f.text_field :location_zip, class: "form-control", placeholder: "ex. 75001" %>
        </div>
        <div class="col-md-6">
          <div class="field-label"><%= @project_type.in?(%w[construction extension]) ? "DPE souhaité" : "DPE / Classe énergétique" %></div>
          <%= f.select :energy_rating,
                options_for_select(%w[A B C D E F G].map { |r| [r, r] }, @project.energy_rating),
                { include_blank: "— Sélectionner —" },
                class: "form-select" %>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to "← Retour", wizard_choose_path, class: "btn btn-ghost-od" %>
      <%= f.submit "Suivant →", class: "btn btn-dark-od" %>
    </div>
  <% end %>
</div>
