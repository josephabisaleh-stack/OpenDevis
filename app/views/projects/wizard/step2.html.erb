<% content_for :head do %>
<style>
  .renovation-card {
    display: flex;
    align-items: center;
    gap: 1.15rem;
    border: 1.5px solid #C8C4BC;
    border-radius: 12px;
    background: #fff;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 0.75rem;
    min-height: 80px;
  }
  .renovation-card:hover { border-color: #2C2A25; }
  .renovation-card:has(input:checked) {
    border-color: #2C2A25;
    background: #EDEAE4;
  }
  .renovation-card input[type="radio"] { display: none; }
  .renovation-card .reno-icon { font-size: 1.7rem; width: 2.2rem; text-align: center; flex-shrink: 0; }
  .renovation-card .reno-desc { font-size: 0.85rem; color: #4A4640; }

  .room-picker {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    padding: 1.25rem;
    background: #FFFFFF;
    margin-top: 0.75rem;
  }

  .room-group {
    border: 1px solid #C8C4BC;
    border-radius: 8px;
    background: #fff;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }
  .room-group-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
  }
  .room-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.95rem;
    color: #2C2A25;
    font-weight: 500;
    flex: 1;
  }
  .room-count-control {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .room-count-control .btn-count {
    width: 26px; height: 26px;
    border: 1px solid #C8C4BC;
    border-radius: 6px;
    background: #fff;
    color: #2C2A25;
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    padding: 0;
  }
  .room-count-control .btn-count:hover { background: #F0EDE8; border-color: #2C2A25; }
  .room-count-control .count-display {
    font-size: 0.9rem;
    font-weight: 600;
    color: #2C2A25;
    min-width: 20px;
    text-align: center;
  }

  .room-instances {
    border-top: 1px solid #C8C4BC;
  }
  .room-instance {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem 0.5rem 2.75rem;
    border-top: 1px solid #F0EDE8;
  }
  .room-instance:first-child { border-top: none; }
  .room-instance-name {
    font-size: 0.88rem;
    color: #2C2A25;
    font-weight: 500;
    min-width: 100px;
  }
  .room-instance-surface {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
  }
  .room-instance-surface input {
    width: 80px;
    border: 1px solid #C8C4BC;
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    font-size: 0.85rem;
    color: #2C2A25;
    background: #fff;
  }
  .room-instance-surface input:focus {
    border-color: #2C2A25;
    outline: none;
    box-shadow: 0 0 0 2px rgba(44,42,37,0.1);
  }
  .room-instance-surface span {
    font-size: 0.8rem;
    color: #4A4640;
  }

  .field-error {
    font-size: 0.8rem;
    color: #C25E4A;
    margin-top: 0.25rem;
  }
</style>
<% end %>

<%
  # Parse stored room data: session[:wizard_rooms] is now an array of hashes
  # [{ "name" => "Chambre 1", "base" => "Chambre", "surface" => "12" }, ...]
  selected_rooms_data = (@selected_rooms.is_a?(Array) && @selected_rooms.first.is_a?(Hash)) ? @selected_rooms : []

  # Group by base name to rebuild counts
  selected_bases = selected_rooms_data.map { |r| r["base"] || r["name"] }.uniq
  selected_counts = selected_rooms_data.group_by { |r| r["base"] || r["name"] }
%>

<div class="container py-4" style="max-width: 620px;">
  <%= render "stepper", current_step: 2, project_type: @project_type %>

  <h2 class="mb-1" style="color: #2C2A25; font-weight: 700;">Type de rénovation</h2>
  <p class="mb-4" style="color: #4A4640;">Sélectionnez le type de travaux envisagés.</p>

  <%= form_with url: wizard_step2_path, method: :post,
      data: { controller: "renovation-type", action: "change->renovation-type#validate" } do |f| %>
    <%
      renovation_types = []
      renovation_types << ["renovation_complete", "🏗️", "Rénovation complète", "Estimation rapide"] unless @project_type == "construction"
      renovation_types << ["par_piece", "🚪", "Rénovation par pièce", "Estimation plus détaillée ou pour des pièces spécifiques"]
    %>
    <% renovation_types.each do |value, icon, label, desc| %>
      <label class="renovation-card">
        <input type="radio" name="renovation_type" value="<%= value %>"
               <%= "checked" if @renovation_type == value %>
               data-action="change->renovation-type#toggleRoomPicker">
        <div class="reno-icon"><%= icon %></div>
        <div>
          <div style="font-weight: 600; font-size: 0.95rem;"><%= label %></div>
          <div class="reno-desc"><%= desc %></div>
        </div>
      </label>
    <% end %>

    <%# Room picker — visible for "par_piece" %>
    <div data-renovation-type-target="roomPicker"
         class="room-picker" <%= @renovation_type == "par_piece" ? "" : "hidden" %>>
      <div class="small fw-semibold mb-2" style="color: #4A4640;">
        Quelles pièces rénover ? <span style="color: #C25E4A;">*</span>
      </div>

      <% Projects::WizardController::PRESET_ROOMS.each do |room| %>
        <%
          is_checked = selected_bases.include?(room)
          room_instances = selected_counts[room] || []
          count = [room_instances.size, 1].max
        %>
        <div class="room-group" data-renovation-type-target="roomGroup" data-room="<%= room %>">
          <div class="room-group-header">
            <label class="room-checkbox-label">
              <input type="checkbox"
                     data-renovation-type-target="roomCheckbox"
                     data-room="<%= room %>"
                     <%= "checked" if is_checked %>
                     data-action="change->renovation-type#toggleRoom">
              <%= room %>
            </label>

            <div class="room-count-control" <%= "hidden" unless is_checked %>
                 data-renovation-type-target="countControl" data-room="<%= room %>">
              <button type="button" class="btn-count"
                      data-action="click->renovation-type#decrement"
                      data-room="<%= room %>">−</button>
              <span class="count-display"
                    data-renovation-type-target="countDisplay" data-room="<%= room %>"><%= count %></span>
              <button type="button" class="btn-count"
                      data-action="click->renovation-type#increment"
                      data-room="<%= room %>">+</button>
            </div>
          </div>

          <div class="room-instances" <%= "hidden" unless is_checked %>
               data-renovation-type-target="roomInstances" data-room="<%= room %>">
            <% if is_checked %>
              <% room_instances.each_with_index do |inst, i| %>
                <div class="room-instance" data-room-index>
                  <div class="room-instance-name"><%= count > 1 ? "#{room} #{i + 1}" : room %></div>
                  <input type="hidden" class="room-field-name" name="rooms[][name]" value="<%= count > 1 ? "#{room} #{i + 1}" : room %>">
                  <input type="hidden" class="room-field-base" name="rooms[][base]" value="<%= room %>">
                  <input type="hidden" class="room-field-surface" name="rooms[][surface]" value="<%= inst["surface"] %>">
                  <div class="room-instance-surface">
                    <input type="number" placeholder="—" min="0" step="0.5"
                           data-action="input->renovation-type#syncSurface"
                           value="<%= inst["surface"] %>">
                    <span>m²</span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @errors&.include?(:rooms) %>
        <div class="field-error">Veuillez sélectionner au moins une pièce</div>
      <% end %>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to wizard_step1_path, class: "btn btn-ghost-od" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Retour
      <% end %>
      <button type="submit" class="btn btn-dark-od"
              data-renovation-type-target="submit"
              <%= "disabled" unless @renovation_type.present? %>>
        Suivant
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  <% end %>
</div>
