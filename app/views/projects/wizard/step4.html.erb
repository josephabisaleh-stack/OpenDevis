<% content_for :head do %>
<style>
  .recap-block {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    background: #fff;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .recap-block-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: #4A4640;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.75rem;
  }
  .recap-row { display: flex; gap: 2rem; flex-wrap: wrap; }
  .recap-item { font-size: 0.9rem; }
  .recap-item .ri-label { color: #4A4640; font-size: 0.8rem; }
  .recap-item .ri-value { color: #2C2A25; font-weight: 500; }

  .cat-chip {
    display: inline-block;
    background: #EDE9E0;
    color: #2C2A25;
    border-radius: 20px;
    padding: 0.25em 0.75em;
    font-size: 0.82rem;
    font-weight: 500;
    margin: 0.2rem;
  }

  .room-recap {
    padding: 0.65rem 0;
    border-bottom: 1px solid #F0EDE8;
  }
  .room-recap:last-child { border-bottom: none; }
  .room-recap-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .room-recap-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: #2C2A25;
  }
  .room-recap-surface {
    font-size: 0.82rem;
    color: #4A4640;
  }
  .room-recap-cats {
    padding-left: 0.25rem;
  }

  .generate-btn {
    background: #2C2A25;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1.05rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .generate-btn:hover { background: #1a1916; }
</style>
<% end %>

<%
reno_labels = {
  "par_piece"           => "Rénovation par pièce",
  "renovation_complete" => "Rénovation complète",
  "energetique"         => "Rénovation énergétique",
  "construction"        => "Construction neuve",
  "extension"           => "Extension / Surélévation"
}
%>

<div class="container py-4" style="max-width: 620px;">
  <%= render "stepper", current_step: 4, project_type: @project_type %>

  <h2 class="mb-1" style="color: #2C2A25; font-weight: 700;">Récapitulatif</h2>
  <p class="mb-4" style="color: #4A4640;">Vérifiez vos choix avant de générer l'estimation.</p>

  <%# Property info block %>
  <div class="recap-block">
    <div class="recap-block-title">Le bien</div>
    <div class="recap-row">
      <% if @project.name.present? %>
        <div class="recap-item">
          <div class="ri-label">Titre</div>
          <div class="ri-value"><%= @project.name %></div>
        </div>
      <% end %>
      <% if @project.property_url.present? %>
        <div class="recap-item">
          <div class="ri-label">Type de bien</div>
          <div class="ri-value"><%= @project.property_url.capitalize %></div>
        </div>
      <% end %>
      <% if @project.location_zip.present? %>
        <div class="recap-item">
          <div class="ri-label">Localisation</div>
          <div class="ri-value"><%= @project.location_zip %></div>
        </div>
      <% end %>
      <% if @project.total_surface_sqm.present? %>
        <div class="recap-item">
          <div class="ri-label">Surface</div>
          <div class="ri-value"><%= @project.total_surface_sqm %> m²</div>
        </div>
      <% end %>
      <% if @project.room_count.present? %>
        <div class="recap-item">
          <div class="ri-label">Nombre de pièces</div>
          <div class="ri-value"><%= @project.room_count %></div>
        </div>
      <% end %>
      <% if @project.energy_rating.present? %>
        <div class="recap-item">
          <div class="ri-label">DPE</div>
          <div class="ri-value"><%= @project.energy_rating %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Renovation type %>
  <div class="recap-block">
    <div class="recap-block-title">Type de rénovation</div>
    <div style="font-size: 0.95rem; font-weight: 500; color: #2C2A25;">
      <%= @project_type.in?(%w[construction extension]) ? reno_labels[@project_type] : (reno_labels[@renovation_type] || "—") %>
    </div>
    <% if @renovation_type == "par_piece" && @selected_rooms.any? %>
      <div class="small mt-1" style="color: #4A4640;">
        <%= @selected_rooms.size %> pièce<%= @selected_rooms.size > 1 ? "s" : "" %> sélectionnée<%= @selected_rooms.size > 1 ? "s" : "" %>
      </div>
    <% end %>
  </div>

  <%# Detailed rooms + categories for "par_piece" mode %>
  <% if @renovation_type == "par_piece" && @selected_rooms.any? %>
    <div class="recap-block">
      <div class="recap-block-title">Détail par pièce</div>
      <% @selected_rooms.each do |room| %>
        <% room_name = room["name"] %>
        <% room_base = room["base"] || room_name %>
        <% room_surface = room["surface"].presence %>
        <% room_cats = @room_categories[room_name] || @room_categories[room_base] || [] %>
        <div class="room-recap">
          <div class="room-recap-header">
            <span class="room-recap-name"><%= room_name %></span>
            <% if room_surface.present? %>
              <span class="room-recap-surface">· <%= room_surface %> m²</span>
            <% end %>
          </div>
          <div class="room-recap-cats">
            <% if room_cats.any? %>
              <% room_cats.each do |slug| %>
                <% cat = @category_labels[slug] %>
                <% if cat %>
                  <span class="cat-chip"><%= cat[:icon] %> <%= cat[:label] %></span>
                <% end %>
              <% end %>
            <% else %>
              <span class="small" style="color: #4A4640;">Aucun travaux sélectionné</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  <%# Global categories for other modes %>
  <% elsif @selected_cats.any? %>
    <div class="recap-block">
      <div class="recap-block-title">Travaux sélectionnés</div>
      <% @selected_cats.each do |cat| %>
        <span class="cat-chip"><%= cat[:icon] %> <%= cat[:label] %></span>
      <% end %>
    </div>
  <% end %>

  <%# Generate form — standing is set to Standard by default %>
  <%= form_with url: wizard_generate_path, method: :post do |f| %>
    <input type="hidden" name="standing" value="2">

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to "← Retour", @project_type == "construction" ? wizard_step1_path : wizard_step3_path, class: "btn btn-ghost-od" %>
      <button type="submit" class="generate-btn">Générer l'estimation ✨</button>
    </div>
  <% end %>
</div>
