<% content_for :head do %>
<style>


  .recap-block {
    border: 1px solid #E8E4DC;
    border-radius: 10px;
    background: #fff;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .recap-row { display: flex; gap: 2rem; flex-wrap: wrap; }
  .recap-item { font-size: 0.9rem; }
  .recap-item .ri-label { color: #9B9588; font-size: 0.8rem; }

  .cat-chip {
    display: inline-block;
    background: #EDE9E0;
    color: #2C2A25;
    border-radius: 20px;
    padding: 0.25em 0.75em;
    font-size: 0.82rem;
    font-weight: 500;
    margin: 0.2rem;
  }

  .standing-btn {
    flex: 1;
    border: 1.5px solid #E8E4DC;
    border-radius: 8px;
    background: #fff;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #6B6560;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s, color 0.12s;
    text-align: center;
  }
  .standing-btn:has(input:checked) {
    border-color: #2C2A25;
    background: #2C2A25;
    color: #fff;
  }
  .standing-btn input { display: none; }

  .generate-btn {
    background: #2C2A25;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1.05rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .generate-btn:hover { background: #1a1916; }
</style>
<% end %>

<%
reno_labels = {
  "home_staging"       => "Home staging",
  "renovation_legere"  => "Rénovation légère",
  "par_piece"          => "Rénovation par pièce",
  "renovation_complete"=> "Rénovation complète",
  "energetique"        => "Rénovation énergétique",
  "construction"       => "Construction neuve",
  "extension"          => "Extension / Surélévation"
}
%>

<div class="container py-4" style="max-width: 620px;">
  <%= render "stepper", current_step: 4, project_type: @project_type %>

  <h2 class="mb-1" style="color: #2C2A25; font-weight: 700;">Récapitulatif</h2>
  <p class="mb-4" style="color: #9B9588;">Vérifiez vos choix avant de générer l'estimation.</p>

  <%# Property info block %>
  <div class="recap-block">
    <div class="recap-row">
      <% if @project.location_zip.present? %>
        <div class="recap-item">
          <div class="ri-label">Code postal</div>
          <div><%= @project.location_zip %></div>
        </div>
      <% end %>
      <% if @project.total_surface_sqm.present? %>
        <div class="recap-item">
          <div class="ri-label">Surface</div>
          <div><%= @project.total_surface_sqm %> m²</div>
        </div>
      <% end %>
      <% if @project.room_count.present? %>
        <div class="recap-item">
          <div class="ri-label">Pièces</div>
          <div><%= @project.room_count %></div>
        </div>
      <% end %>
      <% if @project.energy_rating.present? %>
        <div class="recap-item">
          <div class="ri-label">DPE</div>
          <div><%= @project.energy_rating %></div>
        </div>
      <% end %>
      <div class="recap-item">
        <div class="ri-label">Type de projet</div>
        <div><%= @project_type.in?(%w[construction extension]) ? reno_labels[@project_type] : (reno_labels[@renovation_type] || "—") %></div>
      </div>
    </div>
  </div>

  <%# Selected work categories %>
  <% if @selected_cats.any? %>
    <div class="recap-block">
      <div class="small fw-semibold mb-2" style="color: #9B9588;">Travaux sélectionnés</div>
      <% @selected_cats.each do |cat| %>
        <span class="cat-chip"><%= cat.name %></span>
      <% end %>
    </div>
  <% end %>

  <%# Generate form with standing selector %>
  <%= form_with url: wizard_generate_path, method: :post do |f| %>
    <div class="recap-block">
      <div class="small fw-semibold mb-3" style="color: #2C2A25;">Niveau de standing</div>
      <div class="d-flex gap-2">
        <% [[1, "Éco"], [2, "Standard"], [3, "Premium"]].each do |level, label| %>
          <label class="standing-btn">
            <input type="radio" name="standing" value="<%= level %>" <%= "checked" if level == 2 %>>
            <%= label %>
          </label>
        <% end %>
      </div>
      <div class="small mt-2" style="color: #9B9588;">
        Éco = budget maîtrisé · Standard = rapport qualité/prix · Premium = matériaux haut de gamme
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to "← Retour", @project_type == "construction" ? wizard_step1_path : wizard_step3_path, class: "btn btn-ghost-od" %>
      <button type="submit" class="generate-btn">Générer l'estimation ✨</button>
    </div>
  <% end %>
</div>
