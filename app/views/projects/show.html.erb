<% content_for :head do %>
<style>


  .summary-card {
    border: 1px solid #2563eb;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    background: #2563eb;
    color: #fff;
    height: 100%;
  }
  .summary-card-light {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    background: #fff;
    height: 100%;
  }
  .summary-label  { font-size: 0.8rem; opacity: 0.7; margin-bottom: 0.3rem; }
  .summary-amount { font-size: 1.8rem; font-weight: 700; letter-spacing: -0.5px; }

  .standing-toggle-btn {
    flex: 1;
    border: 1.5px solid #C8C4BC;
    border-radius: 8px;
    background: transparent;
    padding: 0.45rem 0.5rem;
    font-size: 0.84rem;
    font-weight: 500;
    color: #4A4640;
    text-decoration: none;
    text-align: center;
    transition: border-color 0.12s, background 0.12s, color 0.12s;
  }
  .standing-toggle-btn.active { border-color: #2563eb; background: #2563eb; color: #fff; }
  .standing-toggle-btn:hover:not(.active) { border-color: #4A4640; color: #2C2A25; }

  .cat-card {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    background: #fff;
    padding: 1.25rem;
    text-align: center;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    height: 100%;
  }
  .cat-card:hover {
    border-color: #2C2A25;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(44,42,37,0.08);
  }
  .cat-icon  { font-size: 1.8rem; margin-bottom: 0.4rem; line-height: 1; }
  .cat-name  { font-size: 0.88rem; font-weight: 600; color: #2C2A25; margin-bottom: 0.25rem; }
  .cat-count { font-size: 0.78rem; color: #4A4640; margin-bottom: 0.5rem; }
  .cat-total { font-size: 1.05rem; font-weight: 700; color: #2C2A25; }

  .room-row {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    background: #fff;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .room-row:hover { border-color: #2C2A25; color: inherit; }

  .section-title { font-size: 1rem; font-weight: 700; color: #2C2A25; margin-bottom: 1rem; }
</style>
<% end %>

<%
category_icons = {
  "maconnerie"  => "🏗️",
  "plomberie"   => "🔧",
  "electricite" => "⚡",
  "menuiserie"  => "🚪",
  "peinture"    => "🖌️",
  "carrelage"   => "◻️",
  "isolation"   => "🧱",
  "chauffage"   => "🌡️"
}
status_label, status_class = case @project.status
  when "in_progress"     then ["Projet en cours",  "badge-en-cours"]
  when "quote_requested" then ["Devis demandé",    "badge-brouillon"]
  when "quote_received"  then ["Devis reçu",       "badge-termine"]
  when "archived"        then ["Archivé",           "badge-refuse"]
  else                        ["Projet en cours",  "badge-en-cours"]
  end
%>

<div data-controller="delete-confirm archive-confirm">
<div class="container py-4" style="max-width: 1100px;">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
      <%= link_to "← Mes projets", projects_path,
            style: "color: #4A4640; font-size: 0.85rem; text-decoration: none;" %>
      <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
        <h1 style="font-size: 1.5rem; font-weight: 700; color: #2C2A25; margin: 0;">
          <%= @project.location_zip.presence || "Projet sans localisation" %>
        </h1>
        <span class="badge <%= status_class %> fw-normal"
              style="font-size: 0.8rem; padding: 0.35em 0.8em; border-radius: 20px;">
          <%= status_label %>
        </span>
      </div>
      <div style="color: #4A4640; font-size: 0.88rem; margin-top: 4px;">
        <% meta = [] %>
        <% meta << "#{@project.total_surface_sqm&.to_i} m²" if @project.total_surface_sqm.present? %>
        <% meta << "#{@project.room_count} pièces" if @project.room_count.present? %>
        <% meta << "DPE #{@project.energy_rating}" if @project.energy_rating.present? %>
        <%= meta.join(" · ") %>
      </div>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <button class="btn btn-ghost-od btn-sm" disabled title="À venir">Exporter PDF</button>
      <%= link_to "Modifier", wizard_edit_path(@project), class: "btn btn-ghost-od btn-sm" %>
      <% if @project.archived? %>
        <%= button_to "Désarchiver", unarchive_project_path(@project), method: :patch,
              class: "btn btn-ghost-od btn-sm" %>
      <% else %>
        <button type="button" class="btn btn-ghost-od btn-sm"
                data-action="click->archive-confirm#show"
                data-archive-path="<%= archive_project_path(@project) %>"
                data-archive-name="<%= @project.location_zip.presence || @project.name.presence || 'Sans localisation' %>">
          Archiver
        </button>
      <% end %>
      <button type="button" class="btn btn-ghost-od btn-sm"
              style="color: #842029; border-color: #F8D7DA;"
              data-action="click->delete-confirm#show"
              data-delete-path="<%= project_path(@project) %>"
              data-delete-name="<%= @project.location_zip.presence || @project.name.presence || 'Sans localisation' %>">
        Supprimer
      </button>
    </div>
  </div>

  <%# ── Summary bar + categories (Turbo Frame) ─────────────────────────── %>
  <%= turbo_frame_tag "project_summary" do %>

    <%# Summary bar %>
    <div class="row g-3 mb-5">
      <div class="col-md-4">
        <div class="summary-card-light">
          <div class="summary-label" style="color: #4A4640;">Total HT</div>
          <div class="summary-amount" style="font-size: 1.3rem; color: #4A4640;">
            <%= number_to_currency(@total_ht, unit: "€", format: "%n %u",
                  separator: ",", delimiter: "\u202F") %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="summary-card">
          <div class="summary-label">Total TTC</div>
          <div class="summary-amount">
            <%= number_to_currency(@total_ttc, unit: "€", format: "%n %u",
                  separator: ",", delimiter: "\u202F") %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="summary-card-light">
          <div style="font-size: 0.8rem; color: #4A4640; margin-bottom: 0.6rem;">
            Niveau de standing
          </div>
          <div class="d-flex gap-2">
            <% [[1, "Éco"], [2, "Standard"], [3, "Premium"]].each do |level, label| %>
              <%= link_to label, project_path(@project, standing: level),
                    class: "standing-toggle-btn #{"active" if @standing == level}",
                    data: { turbo_frame: "project_summary" } %>
            <% end %>
          </div>
          <div style="font-size: 0.75rem; color: #4A4640; margin-top: 0.5rem;">
            <%= pluralize(@categories_data.sum { |d| d[:count] }, "poste") %>
          </div>
        </div>
      </div>
    </div>

    <%# Categories %>
    <% if @categories_data.any? %>
      <div class="section-title">Par catégorie de travaux</div>
      <div class="row g-3 mb-5">
        <% @categories_data.each do |data| %>
          <% cat = data[:category] %>
          <div class="col-6 col-md-4 col-lg-3">
            <div class="cat-card">
              <div class="cat-icon"><%= category_icons[cat&.slug] || "🔨" %></div>
              <div class="cat-name"><%= cat&.name || "Autre" %></div>
              <div class="cat-count"><%= pluralize(data[:count], "poste") %></div>
              <div class="cat-total">
                <%= number_to_currency(data[:total], unit: "€", format: "%n %u",
                      separator: ",", delimiter: "\u202F") %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4 mb-4" style="border: 1px solid #C8C4BC; border-radius: 10px; background: #fff;">
        <div style="color: #4A4640; font-size: 0.9rem;">
          Aucun poste pour le standing
          <strong><%= ["Éco", "Standard", "Premium"][@standing - 1] %></strong>.
          <% if @project.work_items.any? %>
            Essayez un autre niveau.
          <% else %>
            <br><%= link_to "Ajouter des pièces et des postes", new_project_room_path(@project) %>
            pour construire votre estimation.
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <%# ── Artisan bidding CTA ────────────────────────────────────────────── %>
  <% if @project.bidding_round.nil? %>
    <div style="border: 1.5px dashed #C8C4BC; border-radius: 10px; background: #fff;
                padding: 24px 28px; margin-bottom: 28px;
                display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
      <div>
        <div style="font-weight: 700; color: #2C2A25; margin-bottom: 4px;">Obtenir des devis artisans</div>
        <div style="color: #4A4640; font-size: 0.88rem;">
          Envoyez votre estimation à des artisans locaux et comparez leurs propositions.
        </div>
      </div>
      <%= link_to "Demander des devis →", new_project_bidding_round_path(@project, standing: @standing),
            style: "background: #2563eb; color: #fff; border-radius: 8px; padding: 10px 20px;
                    font-size: 0.9rem; font-weight: 600; text-decoration: none; white-space: nowrap;" %>
    </div>
  <% else %>
    <%
      br = @project.bidding_round
      br_label, br_class = case br.status
        when "sent"        then ["Envoyé",    "badge-en-cours"]
        when "in_progress" then ["En cours",  "badge-en-cours"]
        when "completed"   then ["Terminé",   "badge-termine"]
        else                    ["Brouillon", "badge-brouillon"]
      end
    %>
    <div style="border: 1px solid #C8C4BC; border-radius: 10px; background: #fff;
                padding: 20px 24px; margin-bottom: 28px;
                display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
      <div>
        <div class="d-flex align-items-center gap-2 mb-1">
          <span style="font-weight: 700; color: #2C2A25;">Devis artisans</span>
          <span class="badge <%= br_class %> fw-normal" style="font-size: 0.75rem; padding: 0.25em 0.7em; border-radius: 20px;">
            <%= br_label %>
          </span>
        </div>
        <div style="color: #4A4640; font-size: 0.85rem;">
          <%= br.responses_received %> / <%= br.total_requests %> réponses reçues
          · Niveau <%= br.standing_label %>
          · Date limite <%= l(br.deadline, format: :short) %>
        </div>
      </div>
      <%= link_to "Voir le suivi →", project_bidding_round_path(@project),
            style: "background: transparent; border: 1px solid #C8C4BC; color: #2C2A25; border-radius: 8px;
                    padding: 8px 18px; font-size: 0.88rem; font-weight: 500; text-decoration: none;" %>
    </div>
  <% end %>

  <%# ── Rooms section ───────────────────────────────────────────────────── %>
  <div class="mb-3">
    <div class="section-title mb-0">Par pièce</div>
  </div>

  <% if @rooms.any? %>
    <% @rooms.each do |room| %>
      <%= link_to room, class: "room-row" do %>
        <div>
          <div style="font-weight: 600; color: #2C2A25;"><%= room.name %></div>
          <div style="font-size: 0.82rem; color: #4A4640;">
            <% rparts = [] %>
            <% rparts << "#{room.surface_sqm&.to_i} m²" if room.surface_sqm.present? %>
            <% rparts << pluralize(room.work_items.size, "poste") %>
            <%= rparts.join(" · ") %>
          </div>
        </div>
        <span style="color: #4A4640;">→</span>
      <% end %>
    <% end %>
  <% else %>
    <div class="text-center py-4" style="border: 1px solid #C8C4BC; border-radius: 10px;
         background: #fff; color: #4A4640; font-size: 0.9rem;">
      Aucune pièce pour l'instant.
    </div>
  <% end %>

</div>

  <%# Modal de confirmation de suppression %>
  <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
      <div class="modal-content" style="border: 1px solid #C8C4BC; border-radius: 12px; box-shadow: 0 8px 32px rgba(44,42,37,0.12);">
        <div class="modal-body p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width: 40px; height: 40px; border-radius: 10px; background: #F8D7DA; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#842029" viewBox="0 0 16 16">
                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
              </svg>
            </div>
            <div>
              <div style="font-weight: 700; color: #2C2A25; font-size: 1rem;">Supprimer le projet</div>
              <div style="color: #4A4640; font-size: 0.85rem; margin-top: 2px;">
                "<span data-delete-confirm-target="nameDisplay" style="color: #2C2A25; font-weight: 500;"></span>"
              </div>
            </div>
          </div>
          <p style="color: #4A4640; font-size: 0.88rem; margin: 0 0 1.25rem;">
            Cette action est irréversible. Toutes les pièces et les postes associés à ce projet seront définitivement supprimés.
          </p>
          <div class="d-flex gap-2 justify-content-end">
            <button type="button" data-bs-dismiss="modal"
                    style="border: 1px solid #C8C4BC; background: #fff; color: #4A4640; border-radius: 8px; font-size: 0.88rem; padding: 0.45rem 1rem; cursor: pointer;">
              Annuler
            </button>
            <button type="button" data-action="click->delete-confirm#confirm"
                    style="background: #842029; color: #fff; border: none; border-radius: 8px; font-size: 0.88rem; font-weight: 500; padding: 0.45rem 1rem; cursor: pointer;">
              Supprimer définitivement
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= form_with url: "#", method: :delete,
        data: { delete_confirm_target: "form" },
        style: "display: none;" do |f| %>
    <%= f.submit "Supprimer", style: "display: none;" %>
  <% end %>

  <%# Modal de confirmation d'archivage %>
  <div class="modal fade" id="archiveConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
      <div class="modal-content" style="border: 1px solid #C8C4BC; border-radius: 12px; box-shadow: 0 8px 32px rgba(44,42,37,0.12);">
        <div class="modal-body p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width: 40px; height: 40px; border-radius: 10px; background: #EDE9E0; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#4A4640" viewBox="0 0 16 16">
                <path d="M0 2a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1v7.5a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 1 12.5V5a1 1 0 0 1-1-1zm2 3v7.5A1.5 1.5 0 0 0 3.5 14h9a1.5 1.5 0 0 0 1.5-1.5V5zm13-3H1v2h14zM5 7.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
              </svg>
            </div>
            <div>
              <div style="font-weight: 700; color: #2C2A25; font-size: 1rem;">Archiver le projet</div>
              <div style="color: #4A4640; font-size: 0.85rem; margin-top: 2px;">
                "<span data-archive-confirm-target="nameDisplay" style="color: #2C2A25; font-weight: 500;"></span>"
              </div>
            </div>
          </div>
          <p style="color: #4A4640; font-size: 0.88rem; margin: 0 0 1.25rem;">
            Le projet sera déplacé dans les archives. Vous pourrez le désarchiver à tout moment.
          </p>
          <div class="d-flex gap-2 justify-content-end">
            <button type="button" data-bs-dismiss="modal"
                    style="border: 1px solid #C8C4BC; background: #fff; color: #4A4640; border-radius: 8px; font-size: 0.88rem; padding: 0.45rem 1rem; cursor: pointer;">
              Annuler
            </button>
            <button type="button" data-action="click->archive-confirm#confirm"
                    style="background: #2C2A25; color: #fff; border: none; border-radius: 8px; font-size: 0.88rem; font-weight: 500; padding: 0.45rem 1rem; cursor: pointer;">
              Archiver
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Formulaire PATCH pour l'archivage %>
  <%= form_with url: "#", method: :patch,
        data: { archive_confirm_target: "form" },
        style: "display: none;" do |f| %>
    <%= f.submit "Archiver", style: "display: none;" %>
  <% end %>

</div>
