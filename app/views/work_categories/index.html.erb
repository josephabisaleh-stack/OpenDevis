<%
category_icons = {
  "maconnerie"  => "🏗️",
  "plomberie"   => "🔧",
  "electricite" => "⚡",
  "menuiserie"  => "🚪",
  "peinture"    => "🖌️",
  "carrelage"   => "◻️",
  "isolation"   => "🧱",
  "chauffage"   => "🌡️"
}
%>

<div class="container py-4" style="max-width: 900px;">
  <div class="od-page-title">Catégories de travaux</div>

  <div class="row g-3">
    <% @work_categories.each do |category| %>
      <div class="col-md-4 col-sm-6">
        <%= link_to work_category_path(category), class: "od-card d-block p-4 text-decoration-none" do %>
          <div style="font-size: 1.8rem; line-height: 1; margin-bottom: 0.6rem;">
            <%= category_icons[category.slug] || "🔨" %>
          </div>
          <div style="font-size: 0.95rem; font-weight: 600; color: #2C2A25; margin-bottom: 0.25rem;">
            <%= category.name %>
          </div>
          <div style="font-size: 0.82rem; color: #4A4640;">
            <%= pluralize(category.materials.size, "matériau", "matériaux") %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
