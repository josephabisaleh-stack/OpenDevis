<% content_for :head do %>
<style>
  .notif-row {
    border: 1px solid #E8E4DC;
    border-radius: 10px;
    background: #fff;
    padding: 16px 20px;
    margin-bottom: 10px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    transition: border-color 0.15s;
  }
  .notif-row.unread { border-color: #2C2A25; background: #FAFAF7; }
  .notif-row:hover { border-color: #9B9588; }
  .notif-dot {
    width: 8px; height: 8px; border-radius: 50%; background: #2C2A25;
    flex-shrink: 0; margin-top: 6px;
  }
  .notif-dot.read { background: transparent; border: 1px solid #E8E4DC; }
  .notif-title { font-weight: 600; color: #2C2A25; font-size: 0.9rem; }
  .notif-body { color: #9B9588; font-size: 0.85rem; margin-top: 2px; }
  .notif-time { font-size: 0.78rem; color: #9B9588; white-space: nowrap; }
  .kind-badge { font-size: 0.72rem; padding: 2px 8px; border-radius: 20px; font-weight: 500; }
  .kind-artisan_responded  { background: #D4EDDA; color: #2D6A4F; }
  .kind-all_responded      { background: #D0E8F5; color: #1A5C80; }
  .kind-final_quote_ready  { background: #EDE9E0; color: #6B6560; }
  .kind-manual_review      { background: #FFF3CD; color: #856404; }
</style>
<% end %>

<div class="container py-4" style="max-width: 800px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 style="font-weight: 700; color: #2C2A25; margin-bottom: 2px;">Notifications</h2>
      <div style="color: #9B9588; font-size: 0.9rem;">
        <%= @notifications.count { |n| !n.read } %> non lue<%= @notifications.count { |n| !n.read } > 1 ? "s" : "" %>
      </div>
    </div>
  </div>

  <% if @notifications.any? %>
    <% @notifications.each do |notification| %>
      <div class="notif-row <%= "unread" unless notification.read %>">
        <div class="notif-dot <%= "read" if notification.read %>"></div>
        <div style="flex: 1; min-width: 0;">
          <div class="notif-title">
            <%= notification.title %>
            <span class="kind-badge kind-<%= notification.kind %>"><%= notification.kind.humanize %></span>
          </div>
          <% if notification.body.present? %>
            <div class="notif-body"><%= notification.body %></div>
          <% end %>
          <% if notification.project.present? %>
            <div style="margin-top: 4px;">
              <%= link_to "Voir le projet →", project_path(notification.project),
                    style: "font-size: 0.82rem; color: #2C2A25; text-decoration: none; font-weight: 500;" %>
            </div>
          <% end %>
        </div>
        <div class="d-flex flex-column align-items-end gap-2">
          <span class="notif-time"><%= time_ago_in_words(notification.created_at) %> ago</span>
          <% unless notification.read %>
            <%= button_to "Marquer lu", mark_read_notification_path(notification), method: :post,
                  style: "background: transparent; border: 1px solid #E8E4DC; color: #9B9588; font-size: 0.78rem;
                          padding: 3px 10px; border-radius: 6px; cursor: pointer; white-space: nowrap;" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5" style="border: 1px solid #E8E4DC; border-radius: 10px; background: #fff;">
      <div style="font-size: 2.5rem; margin-bottom: 12px;">🔔</div>
      <div style="font-weight: 600; color: #2C2A25; margin-bottom: 4px;">Aucune notification</div>
      <div style="color: #9B9588; font-size: 0.9rem;">Vous serez notifié quand des artisans répondront à vos demandes.</div>
    </div>
  <% end %>
</div>
