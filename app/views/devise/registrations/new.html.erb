<div class="container py-5" style="max-width: 440px;">

  <div class="text-center mb-4">
    <%= link_to "OpenDevis", root_path,
          style: "font-size: 1.4rem; font-weight: 800; color: #2C2A25; text-decoration: none; letter-spacing: -0.3px;" %>
    <div style="color: #9B9588; font-size: 0.9rem; margin-top: 4px;">Créez votre compte gratuit</div>
  </div>

  <div class="od-form-card">
    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification class: "alert", style: "background:#F8D7DA;color:#842029;border:1px solid #f5c2c7;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;font-size:0.9rem;" %>

      <div class="mb-3">
        <%= f.input :email,
                    label: "Adresse e-mail",
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email", placeholder: "vous@exemple.com" } %>
      </div>
      <div class="mb-3">
        <%= f.input :password,
                    label: "Mot de passe",
                    required: true,
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password", placeholder: "••••••••" } %>
      </div>
      <div class="mb-3">
        <%= f.input :password_confirmation,
                    label: "Confirmer le mot de passe",
                    required: true,
                    input_html: { autocomplete: "new-password", placeholder: "••••••••" } %>
      </div>
      <%= f.button :submit, "Créer mon compte", class: "btn btn-dark-od w-100 mt-2" %>
    <% end %>
  </div>

  <div class="text-center mt-3" style="font-size: 0.85rem; color: #9B9588;">
    <%= render "devise/shared/links" %>
  </div>
</div>
