<div class="container py-5" style="max-width: 440px;">

  <div class="text-center mb-4">
    <%= link_to "OpenDevis", root_path,
          style: "font-size: 1.4rem; font-weight: 800; color: #2C2A25; text-decoration: none; letter-spacing: -0.3px;" %>
    <div style="color: #4A4640; font-size: 0.9rem; margin-top: 4px;">Connectez-vous à votre espace</div>
  </div>

  <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false },
        style: "display:flex; align-items:center; justify-content:center; gap:10px;
                border:1.5px solid #C8C4BC; border-radius:8px; padding:11px 20px;
                background:#fff; color:#2C2A25; font-size:0.95rem; font-weight:600;
                text-decoration:none; margin-bottom:20px; transition:border-color 0.15s;
                width:100%; cursor:pointer;" do %>
    <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
      <path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
      <path d="M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332z" fill="#FBBC05"/>
      <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 7.293C4.672 5.166 6.656 3.58 9 3.58z" fill="#EA4335"/>
    </svg>
    Continuer avec Google
  <% end %>

  <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px; color:#4A4640; font-size:0.82rem;">
    <span style="flex:1; height:1px; background:#C8C4BC;"></span>
    ou
    <span style="flex:1; height:1px; background:#C8C4BC;"></span>
  </div>

  <div class="od-form-card">
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-3">
        <%= f.input :email,
                    label: "Adresse e-mail",
                    required: false,
                    autofocus: true,
                    input_html: { autocomplete: "email", placeholder: "vous@exemple.com" } %>
      </div>
      <div class="mb-3">
        <%= f.input :password,
                    label: "Mot de passe",
                    required: false,
                    input_html: { autocomplete: "current-password", placeholder: "••••••••" } %>
      </div>
      <% if devise_mapping.rememberable? %>
        <div class="mb-3">
          <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" %>
        </div>
      <% end %>
      <%= f.button :submit, "Se connecter", class: "btn btn-dark-od w-100 mt-2" %>
    <% end %>
  </div>

  <div class="text-center mt-3" style="font-size: 0.85rem; color: #4A4640;">
    <%= render "devise/shared/links" %>
  </div>

  <div class="text-center mt-4" style="border-top: 1px solid #C8C4BC; padding-top: 20px;">
    <%= link_to "Je suis un artisan →", new_artisan_session_path,
          class: "btn btn-outline-secondary w-100",
          style: "font-size: 0.9rem; border-color: #C8C4BC; color: #2C2A25;" %>
  </div>
</div>
